            <FaBolt className="text-yellow-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Responde hasta 5 veces más rápido
          </h3>
          <p class="text-sm text-center text-gray-300">
            Plantillas rápidas y respuestas automáticas
          </p>
        </div>
      </div>
    </article>
  </section>

  <!-- Pricing Section -->
  <section
    id="pricing"
    class="relative py-16 px-4 bg-gradient-to-br from-[#1a1a2e] to-[#0a0a0a]"
