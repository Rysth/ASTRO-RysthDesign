        <p class="max-w-2xl mx-auto text-lg text-gray-300">
          Precios claros y justos. Pago anual de implementación + mantenimiento
          mensual.
        </p>

        <!-- Clarificación del modelo de pago -->
        <div
          class="max-w-3xl p-4 mx-auto mt-8 border rounded-xl bg-gradient-to-r from-blue-500/10 to-purple-500/10 border-blue-500/20 backdrop-blur-xl"
        >
          <h3 class="mb-2 text-lg font-bold text-blue-400">
            💡 ¿Cómo Funciona el Pago?
          </h3>
          <div class="grid gap-4 text-sm text-gray-300 md:grid-cols-2">
            <div class="text-center">
              <div class="font-semibold text-yellow-400">
                Implementación Anual
              </div>
              <p>
                Se paga una vez al año por la configuración y soporte del
                sistema
              </p>
            </div>
            <div class="text-center">
              <div class="font-semibold text-green-400">
                Mantenimiento Mensual
              </div>
              <p>Pago mensual por hosting, actualizaciones y soporte técnico</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-center max-w-4xl mx-auto">
        <!-- Plan Único WhatsApp Business -->
        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#25D366]/20 relative max-w-md w-full"
        >
          <!-- Popular Badge -->
          <div class="absolute top-0 transform -translate-y-1/2 right-8">
            <div
              class="bg-gradient-to-r from-[#25D366] to-[#128C7E] text-white px-4 py-1 rounded-full text-sm font-semibold"
            >
              Plan Único
            </div>
          </div>

          <div class="mb-8 text-center">
            <h3 class="mb-4 text-2xl font-bold text-white">
              ChatWoot WhatsApp Business
            </h3>
            <p class="mb-4 text-sm text-gray-400">
              Solución completa para centralizar WhatsApp Business
            </p>
            <div class="space-y-2">
              <div class="flex items-baseline justify-center gap-2">
                <span class="text-4xl font-black text-[#25D366]">$400</span>
                <span class="text-gray-400">implementación anual</span>
              </div>
              <div class="flex items-baseline justify-center gap-2">
                <span class="text-2xl font-bold text-white">$35/mes</span>
                <span class="text-gray-400"
                  >mantenimiento de infraestructura</span
                >
              </div>
            </div>
          </div>

          <!-- What's Included -->
          <div class="mb-8">
            <h4 class="mb-4 text-lg font-bold text-center text-white">
              ¿Qué Incluye?
            </h4>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Configuración completa del sistema
                </span>
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Conexión de WhatsApp Business únicamente
                </span>
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Soporte técnico inicial (30 días)
                </span>
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Guía completa de uso del sistema
                </span>
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300"
                  >Hasta 5 usuarios incluidos</span
                >
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Usuarios adicionales: $5/mes c/u
                </span>
              </div>
              <div class="flex items-center gap-3">
                <FaCheckCircle
                  className="text-[#25D366] text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">
                  Plantillas y respuestas automáticas
                </span>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="text-center">
            <a
              href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20me%20interesa%20el%20plan%20ChatWoot%20WhatsApp%20Business%20(%24500%20implementaci%C3%B3n%20anual%20%2B%20%2425%2Fmes%20-%205%20usuarios).%20%C2%BFPodr%C3%ADamos%20agendar%20una%20reuni%C3%B3n%3F"
