---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/header/PageHeader.astro";

import {
  FaWhatsapp,
  FaChartLine,
  FaUsers,
  FaBolt,
  FaArrowRight,
  FaCheckCircle,
  FaClock,
  FaHeartbeat,
  FaShieldAlt,
  FaRocket,
} from "react-icons/fa";
import ServiceImage from "@/assets/images/services/service_1.webp";
import { Image } from "astro:assets";
---

<Layout
  title="ChatWoot para WhatsApp | Atencion al Cliente para Empresas | RysthDesign"
  description="Centraliza toda la atencion de tu negocio en WhatsApp desde una sola plataforma. Gestiona conversaciones, organiza tu equipo y responde mas rapido."
>
  <PageHeader title="ChatWoot para WhatsApp" currentPage="ChatWoot" />

  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e] overflow-hidden"
  >
    <div class="absolute inset-0 opacity-20">
      <div
        class="absolute rounded-full top-10 left-20 w-96 h-96 bg-green-500/10 blur-3xl"
      >
      </div>
      <div
        class="absolute rounded-full bottom-10 right-20 w-80 h-80 bg-blue-500/10 blur-3xl"
      >
      </div>
    </div>

    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="space-y-8">
          <div class="space-y-6">
            <div
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
            >
              <FaWhatsapp className="text-[#25D366] text-lg" />
              <span class="text-[#25D366] font-semibold text-sm"
                >Atencion profesional por WhatsApp</span
              >
            </div>

            <h1 class="text-4xl font-black text-white md:text-5xl lg:text-6xl">
              Transforma WhatsApp en el centro de atencion
              <span
                class="block bg-gradient-to-r from-[#25D366] to-[#128C7E] bg-clip-text text-transparent"
              >
                de tu empresa
              </span>
            </h1>

            <p class="text-xl leading-relaxed text-gray-300">
              Centraliza toda la atencion de tu negocio en WhatsApp desde una
              sola plataforma. Gestiona conversaciones, organiza tu equipo y
              responde mas rapido desde una plataforma web disenada para
              negocios.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div
              class="text-center p-4 rounded-xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
            >
              <div class="text-2xl font-bold text-[#25D366]">5x</div>
              <div class="text-xs text-gray-400">Mas rapido</div>
            </div>
            <div
              class="p-4 text-center border rounded-xl bg-gradient-to-br from-blue-500/10 to-purple-600/10 border-blue-500/20"
            >
              <div class="text-2xl font-bold text-blue-400">100%</div>
              <div class="text-xs text-gray-400">Organizado</div>
            </div>
            <div
              class="p-4 text-center border rounded-xl bg-gradient-to-br from-purple-500/10 to-pink-600/10 border-purple-500/20"
            >
              <div class="text-2xl font-bold text-purple-400">Web</div>
              <div class="text-xs text-gray-400">Desde PC</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-4">
            <a
              href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20solicitar%20una%20demostracion%20de%20ChatWoot%20para%20organizar%20la%20atencion%20por%20WhatsApp%20de%20mi%20negocio."
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-full text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
            >
              <FaWhatsapp className="text-lg" />
              <span>Solicita una demostracion</span>
            </a>

            <a
              href="#pricing"
              class="inline-flex items-center gap-2 px-8 py-4 text-[#25D366] border-2 border-[#25D366]/50 rounded-full hover:bg-[#25D366]/10 transition-all duration-300 font-semibold backdrop-blur-sm"
            >
              <span>Conoce como funciona</span>
              <FaArrowRight className="text-sm" />
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="relative overflow-hidden shadow-2xl rounded-2xl">
            <div
              class="absolute inset-0 bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 z-10"
            >
            </div>
            <Image
              src={ServiceImage}
              alt="Panel web de atencion por WhatsApp"
              class="object-cover w-full h-80 lg:h-96"
            />
          </div>
        </div>
      </div>
    </article>
  </section>

  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#1a1a2e] to-[#0a0a0a]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          No pierdas mas clientes por respuestas tardias
        </h2>
        <p class="max-w-3xl mx-auto text-lg text-gray-300">
          Cuando WhatsApp crece sin control, los mensajes se acumulan, las
          ventas se enfruan y el equipo pierde seguimiento. ChatWoot convierte
          esa conversacion diaria en un proceso ordenado y medible.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div
          class="p-8 border rounded-2xl bg-gradient-to-br from-red-500/10 to-red-600/10 border-red-500/20"
        >
          <div class="flex items-center gap-3 mb-6">
            <FaClock className="text-red-400 text-3xl" />
            <h3 class="text-2xl font-bold text-red-400">Sin una plataforma</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300">Mensajes olvidados o sin responder</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300">Clientes sin historial claro</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300">Equipo sin asignaciones definidas</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300">Poco control sobre ventas y soporte</span>
            </li>
          </ul>
        </div>

        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
        >
          <div class="flex items-center gap-3 mb-6">
            <FaRocket className="text-[#25D366] text-3xl" />
            <h3 class="text-2xl font-bold text-[#25D366]">Con ChatWoot</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <FaCheckCircle className="text-[#25D366] mt-1 text-lg flex-shrink-0" />
              <span class="text-gray-300">Todas tus conversaciones de WhatsApp en una sola pantalla</span>
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle className="text-[#25D366] mt-1 text-lg flex-shrink-0" />
              <span class="text-gray-300">Chats asignados a cada miembro del equipo</span>
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle className="text-[#25D366] mt-1 text-lg flex-shrink-0" />
              <span class="text-gray-300">Historial completo para dar seguimiento sin perder contexto</span>
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle className="text-[#25D366] mt-1 text-lg flex-shrink-0" />
              <span class="text-gray-300">Respuestas rapidas para atender mejor y vender mas</span>
            </li>
          </ul>
        </div>
      </div>
    </article>
  </section>

  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Ventajas para tu operacion diaria
        </h2>
        <p class="max-w-3xl mx-auto text-lg text-gray-300">
          Una plataforma web pensada para negocios que necesitan orden,
          velocidad de respuesta y seguimiento real de cada cliente.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#25D366]/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
          >
            <FaWhatsapp className="text-[#25D366] text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            WhatsApp centralizado
          </h3>
          <p class="text-sm text-center text-gray-300">
            Gestiona todas las conversaciones desde una bandeja web organizada.
          </p>
        </div>

        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-blue-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-blue-500/20 to-purple-600/20 border-blue-500/30"
          >
            <FaUsers className="text-blue-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Equipo organizado
          </h3>
          <p class="text-sm text-center text-gray-300">
            Crea usuarios, departamentos y asigna chats al agente correcto.
          </p>
        </div>

        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-purple-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-purple-500/20 to-pink-600/20 border-purple-500/30"
          >
            <FaShieldAlt className="text-purple-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Control de clientes
          </h3>
          <p class="text-sm text-center text-gray-300">
            Usa historial, etiquetas y clasificacion para dar mejor seguimiento.
          </p>
        </div>

        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-yellow-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-yellow-500/20 to-orange-600/20 border-yellow-500/30"
          >
            <FaBolt className="text-yellow-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Respuesta mas rapida
          </h3>
          <p class="text-sm text-center text-gray-300">
            Acelera la atencion con respuestas rapidas y procesos claros.
          </p>
        </div>
      </div>
    </article>
  </section>

  <section class="relative py-16 px-4 bg-gradient-to-br from-[#1a1a2e] to-[#0a0a0a]">
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Beneficios incluidos
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {[
          "Centraliza todas las conversaciones de WhatsApp.",
          "Organiza agentes y departamentos.",
          "Asigna chats a miembros del equipo.",
          "Consulta el historial completo de conversaciones.",
          "Usa etiquetas para clasificar clientes.",
          "Ahorra tiempo con respuestas rapidas.",
          "Accede desde computadora.",
          "Trabaja desde una plataforma web accesible desde cualquier lugar.",
          "Mejora el control y seguimiento de clientes.",
        ].map((benefit) => (
          <div
            class="flex items-start gap-3 p-5 rounded-xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 border border-[#25D366]/20"
          >
            <FaCheckCircle className="text-[#25D366] mt-1 flex-shrink-0" />
            <span class="text-gray-300">{benefit}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section
    id="pricing"
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Planes para organizar tu WhatsApp
        </h2>
        <p class="max-w-3xl mx-auto text-lg text-gray-300">
          Elige una implementacion inicial y un plan de mantenimiento segun el
          tamano de tu equipo. El plan anual es ideal para pequenos negocios
          que quieren mantener su plataforma activa todo el ano con un costo
          fijo y soporte incluido.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-yellow-500/20"
        >
          <div class="mb-8 text-center">
            <h3 class="mb-4 text-2xl font-bold text-white">Plan Implementacion</h3>
            <p class="mb-4 text-sm text-gray-400">
              Puesta en marcha completa de la plataforma para tu negocio.
            </p>
            <div class="text-4xl font-black text-yellow-400">USD $350 - $500</div>
            <p class="mt-2 text-xs text-gray-400">
              Segun cantidad de WhatsApp a conectar y personalizacion
            </p>
          </div>
          <div class="space-y-3">
            {[
              "Instalacion completa del sistema.",
              "Configuracion inicial.",
              "Conexion de WhatsApp.",
              "Capacitacion basica.",
              "Configuracion de usuarios.",
              "Personalizacion basica.",
            ].map((item) => (
              <div class="flex items-center gap-3">
                <FaCheckCircle className="text-yellow-400 text-sm flex-shrink-0" />
                <span class="text-sm text-gray-300">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#25D366]/30 relative"
        >
          <div class="absolute top-0 transform -translate-y-1/2 right-8">
            <div
              class="bg-gradient-to-r from-[#25D366] to-[#128C7E] text-white px-4 py-1 rounded-full text-sm font-semibold"
            >
              Recomendado
            </div>
          </div>
          <div class="mb-8 text-center">
            <h3 class="mb-4 text-2xl font-bold text-white">Plan Mensual</h3>
            <p class="mb-4 text-sm text-gray-400">
              Operacion, soporte y mantenimiento continuo.
            </p>
            <div class="space-y-3">
              <div>
                <div class="text-4xl font-black text-[#25D366]">USD $25/mes</div>
                <p class="text-xs text-gray-400">Hasta 3 usuarios</p>
              </div>
              <div class="h-px bg-white/10"></div>
              <div>
                <div class="text-4xl font-black text-[#25D366]">USD $50/mes</div>
                <p class="text-xs text-gray-400">Hasta 10 usuarios</p>
              </div>
            </div>
          </div>
          <div class="space-y-3">
            {[
              "Hosting del sistema.",
              "Mantenimiento tecnico.",
              "Actualizaciones.",
              "Respaldos.",
              "Monitoreo.",
              "Soporte tecnico.",
            ].map((item) => (
              <div class="flex items-center gap-3">
                <FaCheckCircle className="text-[#25D366] text-sm flex-shrink-0" />
                <span class="text-sm text-gray-300">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-blue-500/20"
        >
          <div class="mb-8 text-center">
            <h3 class="mb-4 text-2xl font-bold text-white">Plan Anual</h3>
            <p class="mb-4 text-sm text-gray-400">
              Ideal para pequenos negocios que venden por WhatsApp y necesitan
              estabilidad, soporte y control de costos.
            </p>
            <div class="text-4xl font-black text-blue-400">Desde USD $650/año</div>
            <p class="mt-2 text-xs text-gray-400">
              Hasta 10 usuarios y 1 WhatsApp conectado
            </p>
          </div>
          <div class="space-y-3">
            {[
              "Hosting por 12 meses.",
              "Mantenimiento incluido.",
              "Actualizaciones del sistema.",
              "Respaldos periodicos.",
              "Monitoreo de disponibilidad.",
              "Soporte tecnico durante el periodo.",
              "WhatsApp adicionales se cotizan segun el alcance.",
            ].map((item) => (
              <div class="flex items-center gap-3">
                <FaCheckCircle className="text-blue-400 text-sm flex-shrink-0" />
                <span class="text-sm text-gray-300">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20empezar%20a%20organizar%20mi%20WhatsApp%20con%20ChatWoot.%20Me%20interesa%20conocer%20los%20planes%20y%20agendar%20una%20llamada."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-full text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
        >
          <FaWhatsapp className="text-lg" />
          <span>Empieza a organizar tu WhatsApp</span>
        </a>
      </div>

      <div class="mt-16 text-center">
        <div
          class="max-w-2xl p-6 mx-auto border rounded-2xl bg-gradient-to-r from-blue-500/10 to-purple-500/10 border-blue-500/20 backdrop-blur-xl"
        >
          <div class="flex items-center justify-center gap-2 mb-4">
            <FaClock className="text-blue-400 text-2xl" />
            <h3 class="text-xl font-bold text-blue-400">Tiempo de implementacion</h3>
          </div>
          <p class="mb-4 text-gray-300">
            La implementacion toma entre
            <span class="font-semibold text-blue-400">1 y 3 dias habiles</span>,
            segun la cantidad de WhatsApp a conectar, usuarios y configuracion
            requerida.
          </p>
        </div>
      </div>
    </article>
  </section>

  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#1a1a2e] to-[#0a0a0a]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Preguntas frecuentes
        </h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        {[
          ["Necesito WhatsApp Business?", "Si. Es necesario para trabajar con una cuenta preparada para atencion empresarial."],
          ["Puedo usarlo con varios agentes?", "Si. Puedes organizar usuarios, agentes y departamentos segun tu equipo."],
          ["Puedo acceder desde varias computadoras?", "Si. La plataforma es web y puede utilizarse desde computadoras autorizadas."],
          ["Incluye capacitacion?", "Si. Incluye una capacitacion basica para que tu equipo pueda empezar a usar el sistema."],
          ["Necesito conocimientos tecnicos?", "No. Nosotros realizamos la instalacion, configuracion y puesta en marcha."],
          ["Cuanto demora la implementacion?", "Entre 1 y 3 dias habiles, segun la cantidad de WhatsApp a conectar, usuarios y personalizacion requerida."],
        ].map(([question, answer]) => (
          <details
            class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#25D366]/20"
          >
            <summary class="text-lg font-semibold text-white cursor-pointer">
              {question}
            </summary>
            <p class="mt-4 text-gray-300">{answer}</p>
          </details>
        ))}
      </div>
    </article>
  </section>

  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto text-center">
      <div class="max-w-3xl mx-auto space-y-8">
        <FaChartLine className="mx-auto text-[#25D366] text-5xl" />
        <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Brinda una experiencia mas profesional a tus clientes
        </h2>
        <p class="text-xl text-gray-300">
          No pierdas mas clientes por mensajes olvidados o respuestas tardias.
          Centraliza toda tu atencion de WhatsApp en una sola plataforma y mejora
          la velocidad de respuesta de tu negocio.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
          <a
            href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20agendar%20una%20llamada%20para%20conocer%20como%20funciona%20ChatWoot%20para%20WhatsApp."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-full text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
          >
            <FaWhatsapp className="text-lg" />
            <span>Agenda una llamada</span>
          </a>
        </div>
      </div>
    </article>
  </section>
</Layout>
