---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/header/PageHeader.astro";

import {
  FaWhatsapp,
  FaChartLine,
  FaUsers,
  FaBolt,
  FaArrowRight,
  FaCheckCircle,
  FaClock,
  FaHeartbeat,
  FaShieldAlt,
  FaRocket,
} from "react-icons/fa";
import ServiceImage from "@/assets/images/services/service_1.webp";
import { Image } from "astro:assets";
---

<Layout
  title="ChatWoot - Sistema de Atención al Cliente | WhatsApp Business | RysthDesign"
  description="Transforma la atención a tus clientes con ChatWoot. Centraliza WhatsApp Business en una sola plataforma. $400 implementación anual + $35/mes mantenimiento."
>
  <PageHeader title="ChatWoot - Chat Omnicanal" currentPage="ChatWoot" />

  <!-- Hero Section Chatwoot -->
  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e] overflow-hidden"
  >
    <div class="absolute inset-0 opacity-20">
      <div
        class="absolute rounded-full top-10 left-20 w-96 h-96 bg-green-500/10 blur-3xl"
      >
      </div>
      <div
        class="absolute rounded-full bottom-10 right-20 w-80 h-80 bg-blue-500/10 blur-3xl"
      >
      </div>
    </div>

    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <!-- Left Content -->
        <div class="space-y-8">
          <div class="space-y-6">
            <div
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
            >
              <FaWhatsapp className="text-[#25D366] text-lg" />
              <span class="text-[#25D366] font-semibold text-sm"
                >¿Listo Para Transformar La Atención A Tus Clientes?</span
              >
            </div>

            <h1 class="text-4xl font-black text-white md:text-5xl lg:text-6xl">
              Todo Lo Que Hace Para Tu Negocio
              <span
                class="block bg-gradient-to-r from-[#25D366] to-[#128C7E] bg-clip-text text-transparent"
              >
                ChatWoot
              </span>
            </h1>

            <p class="text-xl leading-relaxed text-gray-300">
              ChatWoot es tu solución de Chat Omnicanal para atención al
              cliente. Centraliza WhatsApp (normal y Business) en una sola
              plataforma usando Evolution API. Nunca pierdas un mensaje
              importante y brinda atención personalizada 24/7 con 5 usuarios
              incluidos por solo $35/mes.
            </p>
          </div>

          <!-- Quick Stats -->
          <div class="grid grid-cols-3 gap-4">
            <div
              class="text-center p-4 rounded-xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
            >
              <div class="text-2xl font-bold text-[#25D366]">5x</div>
              <div class="text-xs text-gray-400">Más Rápido</div>
            </div>
            <div
              class="p-4 text-center border rounded-xl bg-gradient-to-br from-blue-500/10 to-purple-600/10 border-blue-500/20"
            >
              <div class="text-2xl font-bold text-blue-400">100%</div>
              <div class="text-xs text-gray-400">Organizado</div>
            </div>
            <div
              class="p-4 text-center border rounded-xl bg-gradient-to-br from-purple-500/10 to-pink-600/10 border-purple-500/20"
            >
              <div class="text-2xl font-bold text-purple-400">24/7</div>
              <div class="text-xs text-gray-400">Disponible</div>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4">
            <a
              href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20me%20interesa%20ChatWoot%20para%20centralizar%20la%20atenci%C3%B3n%20al%20cliente%20de%20mi%20negocio.%20%C2%BFPodr%C3%ADamos%20agendar%20una%20demo%3F"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-full text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
            >
              <FaWhatsapp className="text-lg" />
              <span>Solicitar Demo Gratuita</span>
            </a>

            <a
              href="#pricing"
              class="inline-flex items-center gap-2 px-8 py-4 text-[#25D366] border-2 border-[#25D366]/50 rounded-full hover:bg-[#25D366]/10 transition-all duration-300 font-semibold backdrop-blur-sm"
            >
              <span>Ver Precios</span>
              <FaArrowRight className="text-sm" />
            </a>
          </div>
        </div>

        <!-- Right - Dashboard Preview -->
        <div class="relative">
          <div class="relative overflow-hidden shadow-2xl rounded-2xl">
            <div
              class="absolute inset-0 bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 z-10"
            >
            </div>
            <Image
              src={ServiceImage}
              alt="ChatWoot Dashboard Preview"
              class="object-cover w-full h-80 lg:h-96"
            />
          </div>
        </div>
      </div>
    </article>
  </section>

  <!-- Before/After Section -->
  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#1a1a2e] to-[#0a0a0a]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          La Transformación Que Necesita Tu Negocio
        </h2>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <!-- Before -->
        <div
          class="p-8 border rounded-2xl bg-gradient-to-br from-red-500/10 to-red-600/10 border-red-500/20"
        >
          <div class="flex items-center gap-3 mb-6">
            <span class="text-4xl">😵</span>
            <h3 class="text-2xl font-bold text-red-400">¡Antes!</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300"
                >Mensajes perdidos en WhatsApp Business</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300"
                >Clientes que repiten su historial</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300"
                >Respuestas lentas = ventas perdidas</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-lg text-red-400">•</span>
              <span class="text-gray-300"
                >Equipo desorganizado y confundido</span
              >
            </li>
          </ul>
        </div>

        <!-- After -->
        <div
          class="p-8 rounded-2xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
        >
          <div class="flex items-center gap-3 mb-6">
            <span class="text-4xl">🤩</span>
            <h3 class="text-2xl font-bold text-[#25D366]">Después</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <FaCheckCircle
                className="text-[#25D366] mt-1 text-lg flex-shrink-0"
              />
              <span class="text-gray-300"
                >Centraliza todos los canales en 1 pantalla</span
              >
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle
                className="text-[#25D366] mt-1 text-lg flex-shrink-0"
              />
              <span class="text-gray-300"
                >Historial único por cliente (sin repetir datos)</span
              >
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle
                className="text-[#25D366] mt-1 text-lg flex-shrink-0"
              />
              <span class="text-gray-300"
                >Plantillas rápidas para responder en segundos</span
              >
            </li>
            <li class="flex items-start gap-3">
              <FaCheckCircle
                className="text-[#25D366] mt-1 text-lg flex-shrink-0"
              />
              <span class="text-gray-300">Organiza a tu equipo fácilmente</span>
            </li>
          </ul>
        </div>
      </div>
    </article>
  </section>

  <!-- Features Section -->
  <section
    class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e]"
  >
    <article class="relative z-10 max-w-screen-xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
          Características Que Transformarán Tu Negocio
        </h2>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <!-- Feature 1 -->
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#25D366]/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
          >
            <FaWhatsapp className="text-[#25D366] text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Atiende por WhatsApp Business
          </h3>
          <p class="text-sm text-center text-gray-300">
            Todos tus mensajes de WhatsApp en una sola pantalla
          </p>
        </div>

        <!-- Feature 2 -->
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-blue-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-blue-500/20 to-purple-600/20 border-blue-500/30"
          >
            <FaUsers className="text-blue-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Nunca pierdas el historial de un cliente
          </h3>
          <p class="text-sm text-center text-gray-300">
            Historial completo de conversaciones y datos
          </p>
        </div>

        <!-- Feature 3 -->
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-purple-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-purple-500/20 to-pink-600/20 border-purple-500/30"
          >
            <FaShieldAlt className="text-purple-400 text-2xl" />
          </div>
          <h3 class="mb-3 text-lg font-bold text-center text-white">
            Organiza a tu equipo fácilmente
          </h3>
          <p class="text-sm text-center text-gray-300">
            Asigna conversaciones y gestiona permisos
          </p>
        </div>

        <!-- Feature 4 -->
        <div
          class="p-6 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-yellow-500/20"
        >
          <div
            class="flex items-center justify-center w-16 h-16 mx-auto mb-4 border rounded-full bg-gradient-to-r from-yellow-500/20 to-orange-600/20 border-yellow-500/30"
