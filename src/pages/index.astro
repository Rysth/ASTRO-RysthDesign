---
import Experience_1 from "@/assets/images/experience/experience_1.png";
import Experience_2 from "@/assets/images/experience/experience_2.png";
import Experience_3 from "@/assets/images/experience/experience_3.png";
import HeroSection from "@/components/sections/HeroSection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import ClientsSection from "@/components/sections/ClientsSection.astro";
import ContactForm from "@/components/forms/ContactForm.astro";
import TechnologySection from "@/sections/general/TechnologySection.astro";
import Layout from "@/layouts/Layout.astro";

// New Zubaz-Inspired Components
import BrandSection from "@/components/sections/BrandSection.astro";
import ContentAlternatingSection from "@/components/sections/ContentAlternatingSection.astro";
import FeaturesGridSection from "@/components/sections/FeaturesGridSection.astro";
import CTASection from "@/components/sections/CTASection.astro";
---

<Layout
  title="Desarrollo Web Profesional | Sitios Web y E-commerce | RysthDesign Guayaquil"
>
  <!-- Hero Section - Professional Landing -->
  <section id="inicio">
    <HeroSection />
  </section>

  <!-- Brand/Trust Section - Social Proof -->
  <BrandSection />

  <!-- Technology Stack Section -->
  <section id="tecnologias">
    <TechnologySection />
  </section>

  <!-- Content Alternating Sections - Showcase Features with Images -->
  <ContentAlternatingSection />

  <!-- Features Grid Section - Complete Feature List -->
  <FeaturesGridSection />

  <!-- Services Section - Core Offerings -->
  <section id="servicios">
    <ServicesSection />
  </section>

  <!-- Clients/Portfolio Section - Social Proof -->
  <section id="clientes">
    <ClientsSection />
  </section>

  <!-- CTA Section - Call to Action -->
  <CTASection />

  <!-- Contact Form Section -->
  <section id="contacto">
    <ContactForm />
  </section>
</Layout>
