---
import { Image } from "astro:assets";
import BrandImage from "../../assets/images/brand/brand.svg";

const whatsappUrl =
  "https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20comprar%20un%20servicio%20digital%20para%20mi%20PC.%20Me%20interesa%20Windows%2C%20Office%20o%20Minecraft.";
const windowsUrl =
  "https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20comprar%20la%20activacion%20de%20Windows%2010%2F11%20de%20%248.";
const officeUrl =
  "https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20comprar%20la%20activacion%20de%20Microsoft%20Office%20de%20%2412.";
const minecraftUrl =
  "https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20comprar%20Minecraft%20Java%20%26%20Bedrock%20para%20PC%20de%20%2424.";
---

<!-- Footer - Inspired by Zubaz Design -->
<footer
  class="relative bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#0f0f1e] border-t border-gray-800"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>
  </div>

  <div class="relative z-10 max-w-screen-xl px-4 py-16 mx-auto">
    <!-- Footer Top -->
    <div
      class="grid gap-12 pb-12 border-b md:grid-cols-2 lg:grid-cols-3 border-gray-800"
    >
      <!-- Column 1: Brand & Description -->
      <div class="space-y-6">
        <a href="/" class="inline-block">
          <Image
            src={BrandImage}
            alt="RysthDesign Logo"
            class="w-auto h-12 transition-transform hover:scale-110"
          />
        </a>
        <p class="text-sm leading-relaxed text-gray-400">
          Servicios digitales para PC en Ecuador: activacion de Windows,
          Microsoft Office y Minecraft Java & Bedrock con soporte por WhatsApp.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="space-y-4">
        <h3 class="text-base font-bold text-white">Navegación</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/#inicio"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Inicio
            </a>
          </li>
          <li>
            <a
              href="/#servicios"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Servicios y precios
            </a>
          </li>
          <li>
            <a
              href="/#faq"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Preguntas frecuentes
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div class="space-y-4">
        <h3 class="text-base font-bold text-white">Servicios</h3>
        <ul class="space-y-3">
          <li>
            <a
              href={windowsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Windows 10/11 - $8
            </a>
          </li>
          <li>
            <a
              href={officeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Microsoft Office - $12
            </a>
          </li>
          <li>
            <a
              href={minecraftUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Minecraft PC - $24
            </a>
          </li>
          <li>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-semibold text-[#25D366] transition-colors hover:text-[#a78bfa] hover:translate-x-1 inline-block"
            >
              Comprar por WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div
      class="flex flex-col items-center justify-between gap-6 pt-8 md:flex-row"
    >
      <!-- Copyright -->
      <p class="text-sm text-center text-gray-400 md:text-left">
        &copy; Copyright 2025, Todos los Derechos Reservados por RysthDesign
      </p>

      <!-- Social Icons -->
      <div class="flex gap-4">
        <a
          href="https://www.instagram.com/rysthdesign/"
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 transition-all duration-300 border rounded-full bg-[#1a1a2e]/60 border-gray-700 hover:border-[#a78bfa] hover:bg-[#a78bfa]/10 group"
          aria-label="Instagram"
        >
          <i
            class="text-lg text-gray-400 transition-colors bx bxl-instagram group-hover:text-[#a78bfa]"
          ></i>
        </a>

        <a
          href="https://www.tiktok.com/@rysthdesign"
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 transition-all duration-300 border rounded-full bg-[#1a1a2e]/60 border-gray-700 hover:border-[#a78bfa] hover:bg-[#a78bfa]/10 group"
          aria-label="TikTok"
        >
          <i
            class="text-lg text-gray-400 transition-colors bx bxl-tiktok group-hover:text-[#a78bfa]"
          ></i>
        </a>

        <a
          href="https://www.facebook.com/rysthdesign"
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 transition-all duration-300 border rounded-full bg-[#1a1a2e]/60 border-gray-700 hover:border-[#a78bfa] hover:bg-[#a78bfa]/10 group"
          aria-label="Facebook"
        >
          <i
            class="text-lg text-gray-400 transition-colors bx bxl-facebook group-hover:text-[#a78bfa]"
          ></i>
        </a>

        <a
          href="https://www.linkedin.com/company/rysthdesign"
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 transition-all duration-300 border rounded-full bg-[#1a1a2e]/60 border-gray-700 hover:border-[#a78bfa] hover:bg-[#a78bfa]/10 group"
          aria-label="LinkedIn"
        >
          <i
            class="text-lg text-gray-400 transition-colors bx bxl-linkedin group-hover:text-[#a78bfa]"
          ></i>
        </a>

        <a
          href="https://github.com/rysthdesign"
          target="_blank"
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 transition-all duration-300 border rounded-full bg-[#1a1a2e]/60 border-gray-700 hover:border-[#a78bfa] hover:bg-[#a78bfa]/10 group"
          aria-label="GitHub"
        >
          <i
            class="text-lg text-gray-400 transition-colors bx bxl-github group-hover:text-[#a78bfa]"
          ></i>
        </a>
      </div>
    </div>
  </div>
</footer>
