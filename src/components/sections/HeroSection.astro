---
import { Image } from "astro:assets";
import WindowsImage from "@/assets/services/RDS-0001-WINDOWS.png";
import OfficeImage from "@/assets/services/RDS-0002-OFFICE.png";
import MinecraftImage from "@/assets/services/RDS-0003-MINECRAFT.png";

const purchaseUrl = "https://shlink.rysthdesign.com/purchase";
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-[#050505] via-[#100f1e] to-[#1a1033] px-4 pb-16 pt-32"
>
  <div class="absolute inset-0 opacity-25">
    <div
      class="absolute -right-32 top-10 h-[520px] w-[520px] rounded-full bg-purple-600/30 blur-3xl"
    >
    </div>
    <div
      class="absolute -left-32 bottom-0 h-[420px] w-[420px] rounded-full bg-blue-500/20 blur-3xl"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto grid max-w-screen-xl items-center gap-12 lg:grid-cols-[1fr_0.92fr]"
  >
    <div class="space-y-8 text-center lg:text-left">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-purple-400/30 bg-white/5 px-4 py-2 text-sm font-semibold uppercase tracking-[0.2em] text-purple-200 backdrop-blur-sm"
      >
        <span class="h-2 w-2 rounded-full bg-[#25D366]"></span>
        Entrega digital en Ecuador
      </div>

      <div class="space-y-5">
        <h1
          class="mx-auto max-w-5xl text-4xl font-black leading-tight text-white md:text-6xl lg:mx-0 lg:text-7xl"
        >
          Servicios digitales rapidos para
          <span
            class="bg-gradient-to-r from-[#a78bfa] to-[#4361ee] bg-clip-text text-transparent"
          >
            tu PC
          </span>
        </h1>

        <p
          class="mx-auto max-w-2xl text-base leading-relaxed text-gray-300 md:text-lg lg:mx-0"
        >
          Activa Windows, Microsoft Office o compra Minecraft Java & Bedrock con
          soporte directo por WhatsApp, entrega rapida y precios claros.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        <div
          class="rounded-2xl border border-purple-400/20 bg-white/[0.04] p-4"
        >
          <p class="text-sm font-semibold text-gray-300">Windows 10/11</p>
          <p class="text-3xl font-black text-white">$8</p>
        </div>
        <div
          class="rounded-2xl border border-purple-400/20 bg-white/[0.04] p-4"
        >
          <p class="text-sm font-semibold text-gray-300">Microsoft Office</p>
          <p class="text-3xl font-black text-white">$12</p>
        </div>
        <div
          class="rounded-2xl border border-purple-400/20 bg-white/[0.04] p-4"
        >
          <p class="text-sm font-semibold text-gray-300">Minecraft PC</p>
          <p class="text-3xl font-black text-white">$24</p>
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-4 lg:justify-start">
        <a
          href={purchaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-full bg-gradient-to-r from-[#25D366] to-[#128C7E] px-8 py-4 text-base font-bold text-white shadow-xl shadow-green-900/20 transition-all duration-300 hover:scale-105 hover:shadow-2xl"
        >
          Comprar por WhatsApp
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center gap-3 rounded-full border border-white/20 bg-white/10 px-8 py-4 text-base font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/20"
        >
          Ver servicios
        </a>
      </div>

      <div
        class="flex flex-wrap justify-center gap-4 text-sm text-gray-300 lg:justify-start"
      >
        <span class="rounded-full bg-white/5 px-4 py-2"
          >Soporte paso a paso</span
        >
        <span class="rounded-full bg-white/5 px-4 py-2">Pago seguro</span>
        <span class="rounded-full bg-white/5 px-4 py-2">Entrega rapida</span>
      </div>
    </div>

    <div class="relative">
      <div class="grid gap-4 sm:grid-cols-2">
        <div
          class="group overflow-hidden rounded-3xl border border-purple-400/30 bg-white/[0.04] p-2 shadow-2xl shadow-purple-950/30 sm:col-span-2"
        >
          <Image
            src={MinecraftImage}
            alt="Minecraft Java y Bedrock para PC por RysthDesign"
            class="h-auto w-full rounded-2xl transition-transform duration-500 group-hover:scale-[1.02]"
            loading="eager"
          />
        </div>
        <div
          class="group overflow-hidden rounded-2xl border border-purple-400/20 bg-white/[0.04] p-2 shadow-xl shadow-purple-950/20"
        >
          <Image
            src={WindowsImage}
            alt="Activacion de Windows 10 y 11 por RysthDesign"
            class="h-auto w-full rounded-xl transition-transform duration-500 group-hover:scale-[1.03]"
            loading="eager"
          />
        </div>
        <div
          class="group overflow-hidden rounded-2xl border border-purple-400/20 bg-white/[0.04] p-2 shadow-xl shadow-purple-950/20"
        >
          <Image
            src={OfficeImage}
            alt="Activacion de Microsoft Office por RysthDesign"
            class="h-auto w-full rounded-xl transition-transform duration-500 group-hover:scale-[1.03]"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
