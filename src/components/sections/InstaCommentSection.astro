---
import { Image } from "astro:assets";
import {
  FaBell,
  FaBolt,
  FaCheck,
  FaComments,
  FaFire,
  FaInstagram,
  FaLink,
  FaRocket,
  FaShieldAlt,
  FaUserShield,
  FaWhatsapp,
} from "react-icons/fa";
import InstaCommentImage from "@/assets/services/RDS-0004-INSTCOMMENT.png";

const instaCommentFeatures = [
  {
    icon: FaComments,
    title: "Respuestas centralizadas",
    description:
      "Responde todos los comentarios de tus publicaciones desde un solo panel sin perder tiempo.",
    color: "from-violet-500 to-purple-600",
  },
  {
    icon: FaLink,
    title: "Vinculación segura",
    description:
      "Conexión oficial con la Instagram Graph API. Sin compartir contraseñas, totalmente seguro.",
    color: "from-blue-500 to-indigo-600",
  },
  {
    icon: FaBell,
    title: "Notificaciones al instante",
    description:
      "Entérate al instante cuando llega un comentario nuevo. Cero comentarios perdidos.",
    color: "from-amber-500 to-orange-600",
  },
  {
    icon: FaUserShield,
    title: "Tu instancia privada",
    description:
      "Cada cliente tiene un entorno aislado: dominio propio, base de datos, licencia y configuración exclusivos.",
    color: "from-emerald-500 to-teal-600",
  },
];

const instaCommentReserveUrl = "https://shlink.rysthdesign.com/instacomment";
const instaCommentDemoParams = new URLSearchParams({
  phone: "593988949117",
  text: "Hola RysthDesign, estoy interesado en ver una demo de RD InstaComment.",
  type: "phone_number",
  app_absent: "0",
});
const instaCommentDemoUrl = `https://api.whatsapp.com/send/?${instaCommentDemoParams.toString()}`;
---

<section
  class="relative overflow-hidden bg-[#050505] px-4 pb-20 pt-28 md:pt-36"
>
  {/* Fondo con gradientes y efectos */}
  <div class="absolute inset-0">
    {/* Gradiente base */}
    <div class="absolute inset-0 bg-gradient-to-br from-[#070707] via-[#0a0a12] to-[#0f0f1e]"></div>
    
    {/* Orbes de luz */}
    <div
      class="absolute -left-20 top-0 h-[600px] w-[600px] rounded-full bg-purple-600/10 blur-[120px]"
    >
    </div>
    <div
      class="absolute -right-20 bottom-0 h-[500px] w-[500px] rounded-full bg-blue-600/8 blur-[100px]"
    >
    </div>
    <div
      class="absolute left-1/2 top-1/3 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-indigo-600/5 blur-[100px]"
    >
    </div>

    {/* Grid sutil */}
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_80%)]"
    >
    </div>
  </div>

  <article class="relative z-10 mx-auto max-w-screen-2xl">
    {/* ========== HERO LAYOUT ========== */}
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      {/* Columna izquierda: Contenido */}
      <div class="order-2 space-y-8 lg:order-1">
        {/* Badges */}
        <div class="flex flex-wrap items-center gap-3">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-purple-500/30 bg-purple-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-purple-300 backdrop-blur-md"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-purple-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2 w-2 rounded-full bg-purple-500"
              ></span>
            </span>
            Servicio Digital
          </span>
          <span
            class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-xs font-bold uppercase tracking-wider text-amber-300 backdrop-blur-md"
          >
            <FaFire className="text-amber-400" />
            Precio de lanzamiento
          </span>
        </div>

        {/* Título */}
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div
              class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-purple-600 to-indigo-600 shadow-lg shadow-purple-900/30"
            >
              <FaInstagram className="text-2xl text-white" />
            </div>
            <div>
              <p
                class="font-jetbrains text-xs font-semibold uppercase tracking-widest text-gray-500"
              >
                RD InstaComment
              </p>
            </div>
          </div>

          <h1
            class="text-4xl font-black leading-[1.1] text-white md:text-5xl lg:text-6xl"
          >
            Gestiona los <br />
            <span
              class="bg-gradient-to-r from-purple-400 via-indigo-400 to-blue-400 bg-clip-text text-transparent"
            >
              Comentarios
            </span>
            <br />
            de Instagram
          </h1>

          <p
            class="max-w-lg text-base leading-relaxed text-gray-400 md:text-lg"
          >
            Responde, organiza y no pierdas ningún comentario de tu negocio en
            Instagram desde un panel centralizado, con tu propia instancia privada.
          </p>
        </div>

        {/* Stats rápidas */}
        <div class="flex flex-wrap gap-6">
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5"
            >
              <FaBolt className="text-sm text-purple-400" />
            </div>
            <div>
              <p class="text-sm font-bold text-white">Respuesta rápida</p>
              <p class="text-xs text-gray-500">En segundos</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5"
            >
              <FaShieldAlt className="text-sm text-emerald-400" />
            </div>
            <div>
              <p class="text-sm font-bold text-white">100% Seguro</p>
              <p class="text-xs text-gray-500">API Oficial Meta</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5"
            >
              <FaRocket className="text-sm text-amber-400" />
            </div>
            <div>
              <p class="text-sm font-bold text-white">Setup incluido</p>
              <p class="text-xs text-gray-500">Configuración gratis</p>
            </div>
          </div>
        </div>

        {/* CTAs */}
        <div class="flex flex-wrap gap-4">
          <a
            href={instaCommentReserveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-full bg-gradient-to-r from-[#25D366] to-[#128C7E] px-8 py-4 text-sm font-bold text-white shadow-xl shadow-green-900/30 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-green-900/40 md:text-base"
          >
            <FaWhatsapp className="text-lg transition-transform group-hover:scale-110" />
            <span>Reservar mi cupo</span>
            <span
              class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-white/10 blur-xl transition-all group-hover:scale-150"
            ></span>
          </a>
          <a
            href={instaCommentDemoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 rounded-full border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white backdrop-blur-md transition-all duration-300 hover:border-white/30 hover:bg-white/10 md:text-base"
          >
            <FaCheck className="text-xs" />
            <span>Ver demo</span>
          </a>
        </div>

        {/* Tags de confianza */}
        <div class="flex flex-wrap gap-3">
          {
            [
              "Configuración incluida",
              "Pago seguro",
              "Solo 3 cupos disponibles",
            ].map((tag) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-xs text-gray-400 backdrop-blur-sm">
                <span class="h-1.5 w-1.5 rounded-full bg-green-500" />
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      {/* Columna derecha: Imagen */}
      <div class="order-1 lg:order-2">
        <div class="relative">
          {/* Glow detrás de la imagen */}
          <div
            class="absolute -inset-4 rounded-[2rem] bg-gradient-to-r from-purple-600/20 via-indigo-600/20 to-blue-600/20 blur-2xl"
          >
          </div>

          {/* Marco de la imagen */}
          <div
            class="group relative overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-3 shadow-2xl shadow-black/40 backdrop-blur-sm"
          >
            <div class="overflow-hidden rounded-[1.2rem]">
              <Image
                src={InstaCommentImage}
                alt="Panel de RD InstaComment para gestionar comentarios de Instagram"
                class="aspect-[4/5] w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
              />
            </div>

            {/* Badge flotante en la imagen */}
            <div
              class="absolute -bottom-6 -right-6 flex items-center gap-3 rounded-2xl border border-white/10 bg-[#0a0a12]/90 p-4 shadow-xl backdrop-blur-xl"
            >
              <div
                class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-purple-600 to-indigo-600"
              >
                <FaInstagram className="text-xl text-white" />
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-400">
                  Compatible con
                </p>
                <p class="text-sm font-bold text-white">
                  Instagram Business
                </p>
              </div>
            </div>

            {/* Badge superior izquierdo */}
            <div
              class="absolute -top-4 left-6 flex items-center gap-2 rounded-full border border-purple-500/30 bg-[#0a0a12]/90 px-4 py-2 shadow-lg backdrop-blur-xl"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"
                ></span>
              </span>
              <span class="text-xs font-semibold text-white">En vivo</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* ========== FEATURES GRID ========== */}
    <div class="mt-24 md:mt-32">
      <div class="mb-12 text-center">
        <p
          class="font-jetbrains text-xs font-semibold uppercase tracking-[0.2em] text-purple-400"
        >
          Características principales
        </p>
        <h2
          class="mt-3 text-2xl font-black text-white md:text-3xl lg:text-4xl"
        >
          Todo lo que necesitas para<br class="hidden md:block" />
          <span class="text-gray-500">gestionar tu comunidad</span>
        </h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          instaCommentFeatures.map((feature, index) => (
            <div class="group relative overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 transition-all duration-500 hover:border-white/10 hover:bg-white/[0.04]">
              {/* Gradiente de fondo al hover */}
              <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-gradient-to-br from-purple-600/10 to-transparent opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100" />

              <div class="relative">
                <div
                  class={`mb-5 inline-flex items-center justify-center rounded-xl bg-gradient-to-br ${feature.color} p-3.5 shadow-lg`}
                >
                  <feature.icon className="text-xl text-white" />
                </div>

                <h3 class="mb-2 text-base font-bold text-white">
                  {feature.title}
                </h3>
                <p class="text-sm leading-relaxed text-gray-400">
                  {feature.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* ========== PRICING SECTION ========== */}
    <div class="mt-24 md:mt-32">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        {/* Card de precio principal */}
        <div class="relative">
          <div
            class="absolute -inset-px rounded-[1.8rem] bg-gradient-to-r from-purple-600 via-indigo-600 to-blue-600 opacity-40 blur-lg"
          >
          </div>
          <div
            class="relative overflow-hidden rounded-[1.7rem] border border-white/10 bg-[#08080f] p-8 md:p-10"
          >
            {/* Decoración */}
            <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-purple-600/10 blur-3xl" />
            <div class="absolute -bottom-10 -left-10 h-40 w-40 rounded-full bg-blue-600/10 blur-3xl" />

            <div class="relative">
              <div class="mb-8 text-center">
                <span
                  class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-xs font-bold uppercase tracking-wider text-amber-300"
                >
                  <FaFire className="text-amber-400" />
                  Precio de lanzamiento fijo
                </span>
                <p class="mt-4 text-sm text-gray-400">
                  Solo para los primeros 3 clientes
                </p>
              </div>

              <div class="mb-8 text-center">
                <p class="text-5xl font-black text-white md:text-6xl">
                  $350<span class="text-2xl font-semibold text-gray-400">/año</span>
                </p>
                <p class="mt-2 text-lg text-gray-400">
                  + <span class="font-bold text-white">$15</span>
                  <span class="text-sm">/mes</span>
                </p>
                <p class="mt-4 text-sm leading-relaxed text-gray-500">
                  Licencia anual de la plataforma más mantenimiento y hosting
                  mensual. Precio congelado todos los años mientras seas
                  cliente activo.
                </p>
              </div>

              <a
                href={instaCommentReserveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex w-full items-center justify-center gap-3 rounded-full bg-gradient-to-r from-purple-600 to-indigo-600 px-6 py-4 text-sm font-bold text-white shadow-lg shadow-purple-900/30 transition-all duration-300 hover:scale-[1.02] hover:shadow-purple-900/50 md:text-base"
              >
                <FaWhatsapp className="text-lg" />
                <span>Solicitar acceso ahora</span>
                <svg
                  class="h-4 w-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>

        {/* Breakdown de precios */}
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-white">
            Desglose del precio
          </h3>

          <div class="space-y-3">
            <div
              class="group flex items-center justify-between rounded-2xl border border-white/[0.06] bg-white/[0.02] px-6 py-5 transition-all hover:border-white/10 hover:bg-white/[0.04]"
            >
              <div class="flex items-center gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-purple-500/10">
                  <FaCheck className="text-purple-400" />
                </div>
                <div>
                  <p class="font-semibold text-white">Licencia anual</p>
                  <p class="text-xs text-gray-500">Se renueva cada año</p>
                </div>
              </div>
              <span class="text-xl font-black text-white">$250</span>
            </div>

            <div
              class="group flex items-center justify-between rounded-2xl border border-white/[0.06] bg-white/[0.02] px-6 py-5 transition-all hover:border-white/10 hover:bg-white/[0.04]"
            >
              <div class="flex items-center gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-500/10">
                  <FaCheck className="text-blue-400" />
                </div>
                <div>
                  <p class="font-semibold text-white">Setup e instalación</p>
                  <p class="text-xs text-gray-500">Configuración inicial</p>
                </div>
              </div>
              <span class="text-xl font-black text-white">$100</span>
            </div>

            <div
              class="group flex items-center justify-between rounded-2xl border border-white/[0.06] bg-white/[0.02] px-6 py-5 transition-all hover:border-white/10 hover:bg-white/[0.04]"
            >
              <div class="flex items-center gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500/10">
                  <FaCheck className="text-emerald-400" />
                </div>
                <div>
                  <p class="font-semibold text-white">
                    Mantenimiento y hosting
                  </p>
                  <p class="text-xs text-gray-500">Mensual recurrente</p>
                </div>
              </div>
              <span class="text-xl font-black text-white">
                $15<span class="text-sm font-normal text-gray-500">/mes</span>
              </span>
            </div>
          </div>

          <div class="rounded-2xl border border-white/[0.06] bg-gradient-to-r from-purple-900/20 to-indigo-900/20 p-5">
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-amber-500/20">
                <FaFire className="text-xs text-amber-400" />
              </div>
              <p class="text-sm leading-relaxed text-gray-300">
                <span class="font-bold text-white">Oferta de lanzamiento:</span>
                Si te unes como uno de los primeros 3 clientes, obtienes el Setup gratuito
                ($100 de descuento). Pagas solo
                <span class="font-bold text-white"> $250/año + $15/mes</span>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* ========== BOTTOM CTA ========== */}
    <div class="mt-24 text-center md:mt-32">
      <div
        class="relative mx-auto max-w-3xl overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.02] p-8 md:p-12"
      >
        <div class="absolute -right-20 -top-20 h-60 w-60 rounded-full bg-purple-600/10 blur-3xl" />
        <div class="absolute -bottom-20 -left-20 h-60 w-60 rounded-full bg-indigo-600/10 blur-3xl" />

        <div class="relative space-y-6">
          <h3 class="text-2xl font-black text-white md:text-3xl">
            ¿Listo para no perder ni un solo comentario?
          </h3>
          <p class="mx-auto max-w-lg text-sm leading-relaxed text-gray-400 md:text-base">
            Únete a los negocios que ya gestionan su comunidad de Instagram de
            forma profesional. Solo 3 cupos disponibles.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href={instaCommentReserveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-3 rounded-full bg-gradient-to-r from-[#25D366] to-[#128C7E] px-8 py-4 text-sm font-bold text-white shadow-xl shadow-green-900/30 transition-all duration-300 hover:scale-105"
            >
              <FaWhatsapp className="text-lg" />
              <span>Reservar mi cupo ahora</span>
            </a>
            <a
              href={instaCommentDemoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/5 px-8 py-4 text-sm font-semibold text-white transition-all hover:bg-white/10"
            >
              <span>Hablar por WhatsApp</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>
</section>
