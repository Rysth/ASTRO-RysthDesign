---
import {
  FaChartLine,
  FaArrowRight,
  FaCheckCircle,
  FaCode,
  FaLaptop,
  FaMobile,
  FaRocket,
  FaShoppingCart,
  FaDatabase,
} from "react-icons/fa";
---

<!-- Services Section -->
<section
  class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e] overflow-hidden"
  id="servicios"
>
  <!-- Elementos decorativos de fondo -->
  <div class="absolute inset-0 opacity-20">
    <div
      class="absolute rounded-full top-10 left-20 w-96 h-96 bg-green-500/10 blur-3xl"
    >
    </div>
    <div
      class="absolute rounded-full bottom-10 right-20 w-80 h-80 bg-blue-500/10 blur-3xl"
    >
    </div>
  </div>

  <article class="relative z-10 max-w-screen-xl mx-auto">
    <!-- Header Section -->
    <div class="mb-16 space-y-6 text-center">
      <div
        class="flex items-center justify-center gap-2 text-[#a78bfa] font-jetbrains text-sm uppercase tracking-wider"
      >
        <div class="w-2 h-2 bg-[#a78bfa] rounded-full animate-pulse"></div>
        <span>Nuestros Servicios</span>
      </div>

      <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl">
        Soluciones Digitales
        <span
          class="text-transparent bg-gradient-to-r from-[#25D366] to-[#128C7E] bg-clip-text"
        >
          Profesionales
        </span>
      </h2>

      <p
        class="max-w-3xl mx-auto text-base leading-relaxed text-gray-300 md:text-lg"
      >
        Construimos soluciones digitales profesionales que transforman tu
        negocio. Desde aplicaciones web a medida hasta tiendas en línea y
        landing pages de alto impacto, tenemos el servicio que necesitas.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid gap-8 mb-12 md:grid-cols-3">
      <!-- Service 1: Custom Web Applications -->
      <div
        class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-[#a78bfa]/20 flex flex-col gap-4"
      >
        <div
          class="flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-r from-[#a78bfa]/20 to-[#4361ee]/20 border border-[#a78bfa]/30"
        >
          <FaCode className="text-[#a78bfa] text-2xl" />
        </div>
        <h4 class="text-xl font-bold text-white">Aplicaciones Web a Medida</h4>
        <p class="text-sm text-gray-400 flex-1">
          Sistemas web completos con React y Ruby on Rails: gestión de
          inventarios, plataformas de reservas, dashboards administrativos y
          cualquier proceso que necesites digitalizar.
        </p>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-[#a78bfa] flex-shrink-0" />
            <span>Stack React + Rails + PostgreSQL</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-[#a78bfa] flex-shrink-0" />
            <span>Integración de pasarelas de pago</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-[#a78bfa] flex-shrink-0" />
            <span>Despliegue con Docker</span>
          </div>
        </div>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 px-5 py-2.5 font-semibold text-white transition-all duration-300 rounded-full shadow-lg bg-gradient-to-r from-[#a78bfa] to-[#4361ee] hover:shadow-xl hover:scale-105 text-sm mt-auto"
        >
          <span>Cotizar</span>
          <FaArrowRight className="text-xs" />
        </a>
      </div>

      <!-- Service 2: Landing Pages -->
      <div
        class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-blue-500/20 flex flex-col gap-4"
      >
        <div
          class="flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-r from-blue-500/20 to-cyan-500/20 border border-blue-500/30"
        >
          <FaLaptop className="text-blue-400 text-2xl" />
        </div>
        <h4 class="text-xl font-bold text-white">
          Landing Pages Profesionales
        </h4>
        <p class="text-sm text-gray-400 flex-1">
          Sitios web corporativos y páginas de aterrizaje optimizadas para
          convertir visitantes en clientes. Diseño moderno, carga ultrarrápida y
          SEO desde el primer día.
        </p>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-blue-400 flex-shrink-0" />
            <span>Astro + TailwindCSS</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-blue-400 flex-shrink-0" />
            <span>Optimización SEO incluida</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-blue-400 flex-shrink-0" />
            <span>Diseño 100% responsive</span>
          </div>
        </div>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 px-5 py-2.5 font-semibold text-white transition-all duration-300 rounded-full shadow-lg bg-gradient-to-r from-blue-500 to-cyan-500 hover:shadow-xl hover:scale-105 text-sm mt-auto"
        >
          <span>Cotizar</span>
          <FaArrowRight className="text-xs" />
        </a>
      </div>

      <!-- Service 3: E-commerce -->
      <div
        class="p-8 rounded-2xl bg-gradient-to-br from-[#1a1a2e]/80 to-[#2d2d44]/80 backdrop-blur-xl border border-green-500/20 flex flex-col gap-4"
      >
        <div
          class="flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-r from-green-500/20 to-teal-500/20 border border-green-500/30"
        >
          <FaShoppingCart className="text-green-400 text-2xl" />
        </div>
        <h4 class="text-xl font-bold text-white">
          E-commerce y Tiendas Online
        </h4>
        <p class="text-sm text-gray-400 flex-1">
          Tiendas en línea completas con carrito de compras, gestión de
          inventario, pagos seguros y panel de administración. Vende tus
          productos o servicios las 24 horas.
        </p>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-green-400 flex-shrink-0" />
            <span>Pasarelas de pago integradas</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-green-400 flex-shrink-0" />
            <span>Panel de administración</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-300">
            <FaCheckCircle className="text-green-400 flex-shrink-0" />
            <span>Gestión de inventario</span>
          </div>
        </div>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 px-5 py-2.5 font-semibold text-white transition-all duration-300 rounded-full shadow-lg bg-gradient-to-r from-green-500 to-teal-500 hover:shadow-xl hover:scale-105 text-sm mt-auto"
        >
          <span>Cotizar</span>
          <FaArrowRight className="text-xs" />
        </a>
      </div>
    </div>
  </article>
</section>
