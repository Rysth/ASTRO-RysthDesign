---
import { Image } from "astro:assets";
import {
  FaBell,
  FaCheckCircle,
  FaComments,
  FaFire,
  FaHeadset,
  FaInstagram,
  FaLink,
  FaLock,
  FaRocket,
  FaUserShield,
  FaWhatsapp,
} from "react-icons/fa";
import WindowsImage from "@/assets/services/RDS-0001-WINDOWS.png";
import OfficeImage from "@/assets/services/RDS-0002-OFFICE.png";
import MinecraftImage from "@/assets/services/RDS-0003-MINECRAFT.png";
import MinecraftReviewImage from "@/assets/services/RDS-0003-0001-MINECRAFT-REVIEW.png";

const instaCommentFeatures = [
  {
    icon: FaComments,
    title: "Respuestas centralizadas",
    description:
      "Responde todos los comentarios de tus publicaciones desde un solo panel.",
  },
  {
    icon: FaLink,
    title: "Vinculacion segura",
    description:
      "Conexion oficial con la Instagram Graph API, sin compartir contrasenas.",
  },
  {
    icon: FaBell,
    title: "Notificaciones al instante",
    description: "Enterate al instante cuando llega un comentario nuevo.",
  },
  {
    icon: FaUserShield,
    title: "Tu instancia privada",
    description:
      "Cada cliente tiene un entorno aislado: dominio, base de datos, licencia y configuracion exclusivos.",
  },
];

const instaCommentReserveMessage = encodeURIComponent(
  "Hola, quiero reservar uno de los 3 cupos de Gestion de Comentarios de Instagram",
);
const instaCommentDemoMessage = encodeURIComponent(
  "Hola, quiero ver una demo de RD InstaComment antes de reservar mi cupo",
);
const instaCommentReserveUrl = `https://wa.me/593988949117?text=${instaCommentReserveMessage}`;
const instaCommentDemoUrl = `https://wa.me/593988949117?text=${instaCommentDemoMessage}`;

const services = [
  {
    name: "Windows 10/11",
    price: "$8",
    description:
      "Activa tu Windows de forma rapida con soporte durante el proceso.",
    image: WindowsImage,
    alt: "Activacion de Windows 10 y 11",
    cta: "Quiero activar Windows",
    href: "https://shlink.rysthdesign.com/windows",
    benefits: [
      "Compatible con Windows 10 y 11",
      "Ideal para PC nuevas o formateadas",
      "Soporte paso a paso",
    ],
  },
  {
    name: "Microsoft Office",
    price: "$12",
    description:
      "Activa Office para usar Word, Excel, PowerPoint y mas en tu PC.",
    image: OfficeImage,
    alt: "Activacion de Microsoft Office",
    cta: "Quiero activar Office",
    href: "https://shlink.rysthdesign.com/office",
    benefits: [
      "Word, Excel y PowerPoint",
      "Ideal para estudio y trabajo",
      "Acompanamiento por WhatsApp",
    ],
  },
  {
    name: "Minecraft Java & Bedrock",
    price: "$24",
    description: "Compra Minecraft para PC y recibelo en tu cuenta Microsoft.",
    image: MinecraftImage,
    alt: "Minecraft Java y Bedrock para PC",
    cta: "Quiero comprar Minecraft",
    href: "https://shlink.rysthdesign.com/minecraft",
    benefits: [
      "Java Edition incluida",
      "Bedrock Edition incluida",
      "Se agrega a tu cuenta Microsoft",
    ],
  },
];

const faqs = [
  {
    question: "Como recibo el producto?",
    answer:
      "Todo se coordina por WhatsApp. Te doy las instrucciones y te acompano hasta que el servicio quede listo.",
  },
  {
    question: "Cuanto tarda la entrega?",
    answer:
      "Normalmente la atencion es rapida. Si estoy en horario laboral, te respondo apenas tenga disponibilidad y te dejo el proceso claro.",
  },
  {
    question: "Que metodos de pago aceptan?",
    answer:
      "Puedes escribir por WhatsApp para confirmar el metodo disponible antes de avanzar con la compra.",
  },
  {
    question: "Minecraft queda en mi cuenta Microsoft?",
    answer:
      "Si, el servicio esta pensado para que puedas usar Minecraft Java & Bedrock en tu cuenta Microsoft para PC.",
  },
];
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-[#070707] via-[#100f1e] to-[#140f28] px-4 py-20"
  id="servicios"
>
  <div class="absolute inset-0 opacity-20">
    <div
      class="absolute left-10 top-20 h-96 w-96 rounded-full bg-purple-500/20 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-10 right-10 h-80 w-80 rounded-full bg-green-500/10 blur-3xl"
    >
    </div>
  </div>

  <article class="relative z-10 mx-auto max-w-screen-xl space-y-16">
    <div class="mx-auto max-w-3xl space-y-5 text-center">
      <div
        class="font-jetbrains text-sm font-semibold uppercase tracking-[0.24em] text-[#a78bfa]"
      >
        Servicios estrella
      </div>
      <h2 class="text-3xl font-black text-white md:text-5xl">
        Compra digital, soporte directo y precios claros
      </h2>
      <p class="text-base leading-relaxed text-gray-300 md:text-lg">
        Tres productos simples para vender por pauta: Windows, Office y
        Minecraft. Sin cotizaciones largas, sin reuniones y con cierre por
        WhatsApp.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="flex flex-col overflow-hidden rounded-3xl border border-purple-400/20 bg-white/[0.04] shadow-2xl shadow-purple-950/20 backdrop-blur-xl">
            <div class="relative overflow-hidden border-b border-purple-400/10 bg-black/30 p-3">
              <Image
                src={service.image}
                alt={service.alt}
                class="aspect-square w-full rounded-2xl object-cover transition-transform duration-500 hover:scale-[1.02]"
              />
            </div>
            <div class="flex flex-1 flex-col gap-5 p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-2xl font-black text-white">{service.name}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-400">
                    {service.description}
                  </p>
                </div>
                <div class="rounded-2xl bg-gradient-to-r from-[#a78bfa] to-[#4361ee] px-4 py-3 text-center shadow-lg shadow-purple-900/30">
                  <p class="text-xs font-bold uppercase tracking-wider text-white/80">
                    Precio
                  </p>
                  <p class="text-3xl font-black text-white">{service.price}</p>
                </div>
              </div>

              <div class="space-y-3">
                {service.benefits.map((benefit) => (
                  <div class="flex items-center gap-3 text-sm text-gray-300">
                    <FaCheckCircle className="shrink-0 text-[#25D366]" />
                    <span>{benefit}</span>
                  </div>
                ))}
              </div>

              <a
                href={service.href}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-auto inline-flex items-center justify-center gap-3 rounded-full bg-gradient-to-r from-[#25D366] to-[#128C7E] px-6 py-4 font-bold text-white shadow-lg shadow-green-950/30 transition-all duration-300 hover:scale-105"
              >
                <FaWhatsapp />
                <span>{service.cta}</span>
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <div class="space-y-6">
      <div
        class="font-jetbrains text-sm font-semibold uppercase tracking-[0.24em] text-[#a78bfa]"
      >
        Nuevo servicio
      </div>

      <div
        class="overflow-hidden rounded-3xl border border-purple-400/20 bg-white/[0.04] shadow-2xl shadow-purple-950/20 backdrop-blur-xl"
      >
        <div
          class="grid gap-8 p-6 md:p-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start"
        >
          <div class="space-y-6">
            <div class="flex flex-wrap items-center gap-3">
              <span
                class="inline-flex items-center gap-2 rounded-full border border-purple-400/30 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-purple-200 backdrop-blur-sm"
              >
                <span class="h-2 w-2 rounded-full bg-[#25D366]"></span>
                Servicio Digital
              </span>
              <span
                class="inline-flex items-center gap-2 rounded-full border border-amber-400/40 bg-amber-500/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.15em] text-amber-300"
              >
                <FaFire className="shrink-0" />
                Precio de lanzamiento fijo - solo para los primeros 3 clientes
              </span>
            </div>

            <div class="flex items-start gap-4">
              <div class="rounded-2xl bg-purple-500/15 p-4 text-[#a78bfa]">
                <FaInstagram className="text-2xl" />
              </div>
              <div>
                <h3 class="text-2xl font-black text-white md:text-3xl">
                  Gestion de Comentarios de Instagram
                </h3>
                <p
                  class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500"
                >
                  RD InstaComment
                </p>
              </div>
            </div>

            <p class="text-sm leading-relaxed text-gray-300 md:text-base">
              Responde, organiza y no pierdas ningun comentario de tu negocio
              en Instagram desde un panel centralizado, con tu propia
              instancia privada.
            </p>

            <div class="grid gap-4 sm:grid-cols-2">
              {
                instaCommentFeatures.map((feature) => (
                  <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                    <div class="shrink-0 rounded-xl bg-purple-500/15 p-2.5 text-[#a78bfa]">
                      <feature.icon />
                    </div>
                    <div>
                      <h4 class="text-sm font-bold text-white">
                        {feature.title}
                      </h4>
                      <p class="mt-1 text-xs leading-relaxed text-gray-400">
                        {feature.description}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>

            <div class="flex flex-wrap gap-3">
              <a
                href={instaCommentReserveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-3 rounded-full bg-gradient-to-r from-[#25D366] to-[#128C7E] px-6 py-4 font-bold text-white shadow-lg shadow-green-950/30 transition-all duration-300 hover:scale-105"
              >
                <FaWhatsapp />
                <span>Reservar mi cupo</span>
              </a>
              <a
                href={instaCommentDemoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-3 rounded-full border border-white/20 bg-white/10 px-6 py-4 font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/20"
              >
                Ver demo
              </a>
            </div>

            <div class="flex flex-wrap gap-3 text-xs text-gray-300">
              <span class="rounded-full bg-white/5 px-4 py-2">
                Configuracion incluida
              </span>
              <span class="rounded-full bg-white/5 px-4 py-2">
                Pago seguro
              </span>
              <span class="rounded-full bg-white/5 px-4 py-2">
                Solo 3 cupos disponibles
              </span>
            </div>
          </div>

          <div class="space-y-4">
            <div
              class="rounded-2xl bg-gradient-to-r from-[#a78bfa] to-[#4361ee] p-6 text-center shadow-lg shadow-purple-900/30"
            >
              <p
                class="text-xs font-bold uppercase tracking-wider text-white/80"
              >
                Precio de lanzamiento
              </p>
              <p class="mt-2 text-3xl font-black text-white md:text-4xl">
                $250/año + $15/mes
              </p>
              <p class="mt-3 text-xs leading-relaxed text-white/80">
                Licencia anual de la plataforma mas mantenimiento y hosting
                mensual. Precio congelado todos los años mientras seas cliente
                activo.
              </p>
            </div>

            <div
              class="overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]"
            >
              <div
                class="flex items-center justify-between border-b border-white/10 px-5 py-4"
              >
                <span class="text-sm text-gray-300">Licencia anual</span>
                <span class="text-sm font-bold text-white">
                  $250{" "}
                  <span class="font-normal text-gray-500">
                    / se renueva cada año
                  </span>
                </span>
              </div>
              <div class="flex items-center justify-between px-5 py-4">
                <span class="text-sm text-gray-300">
                  Mantenimiento y hosting
                </span>
                <span class="text-sm font-bold text-white">
                  $15 <span class="font-normal text-gray-500">/ mes</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="grid gap-6 rounded-3xl border border-purple-400/20 bg-white/[0.04] p-6 md:grid-cols-3 md:p-8"
    >
      <div class="flex items-start gap-4">
        <div class="rounded-2xl bg-purple-500/15 p-4 text-[#a78bfa]">
          <FaRocket />
        </div>
        <div>
          <h3 class="font-bold text-white">Entrega rapida</h3>
          <p class="mt-1 text-sm text-gray-400">
            Proceso pensado para ventas digitales sin reuniones largas.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="rounded-2xl bg-green-500/15 p-4 text-[#25D366]">
          <FaHeadset />
        </div>
        <div>
          <h3 class="font-bold text-white">Soporte por WhatsApp</h3>
          <p class="mt-1 text-sm text-gray-400">
            Te acompano paso a paso durante la compra o activacion.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="rounded-2xl bg-blue-500/15 p-4 text-blue-300">
          <FaLock />
        </div>
        <div>
          <h3 class="font-bold text-white">Compra segura</h3>
          <p class="mt-1 text-sm text-gray-400">
            Atencion directa, confirmacion y evidencia del proceso.
          </p>
        </div>
      </div>
    </div>

    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <div
          class="font-jetbrains text-sm font-semibold uppercase tracking-[0.24em] text-[#a78bfa]"
        >
          Prueba social
        </div>
        <h2 class="text-3xl font-black text-white md:text-4xl">
          Clientes reales, entregas verificadas y soporte directo
        </h2>
        <p class="text-gray-300">
          Usa reseñas y capturas reales para aumentar confianza en las pautas.
          Minecraft sera el primer producto a validar por su ticket mas alto.
        </p>
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-2xl font-black text-white">$40</p>
            <p class="text-sm text-gray-400">Pack completo</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-2xl font-black text-white">$30</p>
            <p class="text-sm text-gray-400">Minecraft + Windows</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
            <p class="text-2xl font-black text-white">$18</p>
            <p class="text-sm text-gray-400">Windows + Office</p>
          </div>
        </div>
      </div>

      <div
        class="overflow-hidden rounded-3xl border border-purple-400/20 bg-white/[0.04] p-3 shadow-2xl shadow-purple-950/30"
      >
        <Image
          src={MinecraftReviewImage}
          alt="Venta finalizada de Minecraft con cliente satisfecho"
          class="w-full rounded-2xl"
        />
      </div>
    </div>

    <div id="faq" class="mx-auto max-w-4xl scroll-mt-24 space-y-6">
      <div class="text-center">
        <p
          class="font-jetbrains text-sm font-semibold uppercase tracking-[0.24em] text-[#a78bfa]"
        >
          Preguntas frecuentes
        </p>
        <h2 class="mt-3 text-3xl font-black text-white">Antes de comprar</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          faqs.map((faq) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
              <h3 class="font-bold text-white">{faq.question}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray-400">
                {faq.answer}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </article>
</section>
