---
import { FaArrowRight, FaCheck, FaWhatsapp } from "react-icons/fa";

const whatsappUrl =
  "https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20comprar%20un%20servicio%20digital.%20Me%20puedes%20ayudar%20con%20Windows%2C%20Office%20o%20Minecraft%3F";
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-[#4361ee] via-[#5b2bd6] to-[#12091f] px-4 py-20"
>
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl text-center">
    <div
      class="mx-auto mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-bold uppercase tracking-[0.2em] text-white"
    >
      <span class="h-2 w-2 rounded-full bg-[#25D366]"></span>
      Compra digital por WhatsApp
    </div>

    <h2 class="text-4xl font-black leading-tight text-white md:text-6xl">
      Listo para activar tu PC o comprar Minecraft?
    </h2>

    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-white/85">
      Escríbeme, dime que producto necesitas y te ayudo con el proceso: Windows
      desde $8, Office desde $12 y Minecraft Java & Bedrock por $24.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 rounded-full bg-white px-8 py-5 font-bold text-[#4361ee] shadow-xl transition-all duration-300 hover:scale-105 hover:bg-white/90"
      >
        <FaWhatsapp className="text-xl text-[#25D366]" />
        <span>Escribeme por WhatsApp</span>
        <FaArrowRight
          className="transition-transform group-hover:translate-x-1"
        />
      </a>

      <a
        href="#servicios"
        class="inline-flex items-center gap-3 rounded-full border border-white/30 bg-white/10 px-8 py-5 font-semibold text-white backdrop-blur-md transition-all duration-300 hover:bg-white/20"
      >
        Ver precios
      </a>
    </div>

    <div class="mt-10 grid gap-4 text-left sm:grid-cols-3">
      <div
        class="rounded-2xl border border-white/15 bg-white/10 p-5 text-white backdrop-blur-md"
      >
        <FaCheck className="mb-3 text-[#25D366]" />
        <p class="font-bold">Entrega digital</p>
        <p class="mt-1 text-sm text-white/70">
          Sin reuniones largas ni procesos complicados.
        </p>
      </div>
      <div
        class="rounded-2xl border border-white/15 bg-white/10 p-5 text-white backdrop-blur-md"
      >
        <FaCheck className="mb-3 text-[#25D366]" />
        <p class="font-bold">Soporte directo</p>
        <p class="mt-1 text-sm text-white/70">
          Atencion personalizada durante la compra.
        </p>
      </div>
      <div
        class="rounded-2xl border border-white/15 bg-white/10 p-5 text-white backdrop-blur-md"
      >
        <FaCheck className="mb-3 text-[#25D366]" />
        <p class="font-bold">Precios claros</p>
        <p class="mt-1 text-sm text-white/70">
          Windows $8, Office $12 y Minecraft $24.
        </p>
      </div>
    </div>
  </div>
</section>
