---
import { FaCode, FaMobileAlt, FaRocket, FaDatabase } from "react-icons/fa";
import { Image } from "astro:assets";
import Project_1 from "@/assets/images/projects/project_1.png";
---

<!-- Content Alternating Section - Web Applications Showcase -->
<div
  class="relative bg-gradient-to-br from-[#0a0a0a] via-[#100f1e] to-[#1a1a2e]"
>
  <!-- Section: Custom Web Applications - Image Left, Content Right -->
  <section class="relative px-4 py-16 overflow-hidden md:py-20">
    <!-- Background Elements -->
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute rounded-full top-20 left-10 w-96 h-96 bg-purple-500/20 blur-3xl"
      >
      </div>
      <div
        class="absolute rounded-full bottom-20 right-10 w-80 h-80 bg-blue-500/20 blur-3xl"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-screen-xl mx-auto">
      <div class="grid items-center gap-8 md:gap-12 md:grid-cols-2 lg:gap-16">
        <!-- Image Left -->
        <div class="relative order-2 md:order-1">
          <div class="relative">
            <!-- Main Image with Shadow -->
            <div
              class="relative overflow-hidden shadow-2xl rounded-2xl shadow-purple-900/20"
            >
              <Image
                src={Project_1}
                alt="Aplicación Web a Medida - QuickInventory"
                class="object-cover w-full h-auto transition-transform duration-500 hover:scale-105"
              />
            </div>

            <!-- Floating Card 1 -->
            <div
              class="absolute -right-4 top-8 md:-right-8 bg-gradient-to-br from-[#1a1a2e]/95 to-[#2d2d44]/95 backdrop-blur-xl border border-[#a78bfa]/30 rounded-xl p-4 shadow-lg animate-float hidden md:block max-w-[200px]"
            >
              <div class="flex items-center gap-3 mb-2">
                <div
                  class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-[#a78bfa]/20 to-[#4361ee]/20"
                >
                  <FaCode className="text-[#a78bfa] text-sm" />
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">Full Stack</div>
                  <div class="text-xs text-gray-400">React + Rails</div>
                </div>
              </div>
            </div>

            <!-- Floating Card 2 -->
            <div
              class="absolute -left-4 bottom-8 md:-left-8 bg-gradient-to-br from-[#1a1a2e]/95 to-[#2d2d44]/95 backdrop-blur-xl border border-blue-500/30 rounded-xl p-4 shadow-lg animate-float hidden md:block max-w-[180px]"
              style="animation-delay: 1s;"
            >
              <div class="flex items-center gap-3">
                <div
                  class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-600/20"
                >
                  <FaDatabase className="text-blue-400 text-sm" />
                </div>
                <div>
                  <div class="text-xs font-semibold text-white">PostgreSQL</div>
                  <div class="text-xs text-gray-400">Producción</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content Right -->
        <div class="order-1 space-y-6 md:order-2">
          <div
            class="flex items-center gap-2 text-[#a78bfa] font-jetbrains text-sm uppercase tracking-wider"
          >
            <div class="w-2 h-2 bg-[#a78bfa] rounded-full animate-pulse"></div>
            <span>Desarrollo a Medida</span>
          </div>

          <h2
            class="text-3xl font-black leading-tight text-white md:text-4xl lg:text-5xl"
          >
            Construimos aplicaciones que
            <span
              class="bg-gradient-to-r from-[#a78bfa] to-[#4361ee] bg-clip-text text-transparent"
            >
              impulsan tu negocio
            </span>
          </h2>

          <p class="text-base leading-relaxed text-gray-300 md:text-lg">
            Transformamos tus procesos en sistemas web robustos y escalables.
            Desde aplicaciones de gestión interna hasta plataformas de cara al
            cliente, desarrollamos soluciones a la medida exacta de lo que
            necesitas.
          </p>

          <!-- Features List -->
          <div class="space-y-4">
            <!-- Feature 1 -->
            <div class="flex items-start gap-4">
              <div
                class="flex items-center justify-center flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-r from-[#a78bfa]/20 to-[#4361ee]/20 border border-[#a78bfa]/30"
              >
                <FaCode className="text-[#a78bfa] text-lg" />
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">
                  Stack Moderno y Probado
                </h4>
                <p class="text-sm text-gray-400">
                  React en el frontend, Ruby on Rails como API robusta en el
                  backend, PostgreSQL para persistencia confiable y Docker para
                  despliegues reproducibles.
                </p>
              </div>
            </div>

            <!-- Feature 2 -->
            <div class="flex items-start gap-4">
              <div
                class="flex items-center justify-center flex-shrink-0 w-12 h-12 border rounded-full bg-gradient-to-r from-blue-500/20 to-purple-600/20 border-blue-500/30"
              >
                <FaRocket className="text-blue-400 text-lg" />
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">
                  Datos en Tiempo Real
                </h4>
                <p class="text-sm text-gray-400">
                  Sistemas con persistencia en base de datos, validaciones de
                  negocio sólidas e integraciones con pasarelas de pago y
                  servicios externos.
                </p>
              </div>
            </div>

            <!-- Feature 3 -->
            <div class="flex items-start gap-4">
              <div
                class="flex items-center justify-center flex-shrink-0 w-12 h-12 border rounded-full bg-gradient-to-r from-green-500/20 to-teal-600/20 border-green-500/30"
              >
                <FaMobileAlt className="text-green-400 text-lg" />
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold text-white">
                  UI Profesional y Responsive
                </h4>
                <p class="text-sm text-gray-400">
                  Interfaces construidas con TailwindCSS y componentes modernos
                  como ShadCN, optimizadas para escritorio y móvil desde el
                  primer día.
                </p>
              </div>
            </div>
          </div>

          <!-- CTA Highlight -->
          <div
            class="p-4 border rounded-xl bg-gradient-to-r from-[#a78bfa]/10 to-[#4361ee]/10 border-[#a78bfa]/20"
          >
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <div class="text-sm font-semibold text-white">
                  ¿Tienes un proyecto en mente?
                </div>
                <p class="text-xs text-gray-400">
                  Cuéntanos tu idea y construimos juntos
                </p>
              </div>
              <a
                href="#contacto"
                class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-white transition-all duration-300 rounded-full shadow-lg bg-gradient-to-r from-[#a78bfa] to-[#4361ee] hover:shadow-xl hover:scale-105"
              >
                <span>Cotizar Ahora</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
