---
import {
  FaWhatsapp,
  FaCheckCircle,
  FaArrowRight,
  FaChartLine,
  FaUsers,
  FaBolt,
} from "react-icons/fa";
import ServiceImage from "@/assets/images/services/service_1.webp";
import { Image } from "astro:assets";
---

<!-- Chatwoot Spotlight Section - Servicio Destacado -->
<section
  class="relative py-16 px-4 bg-gradient-to-br from-[#0a0a0a] via-[#0f1a14] to-[#1a1a2e] overflow-hidden"
>
  <!-- Green Glow Background -->
  <div class="absolute inset-0 opacity-20">
    <div
      class="absolute rounded-full top-10 left-20 w-96 h-96 bg-green-500/15 blur-3xl"
    >
    </div>
    <div
      class="absolute rounded-full bottom-10 right-20 w-80 h-80 bg-emerald-500/10 blur-3xl"
    >
    </div>
  </div>

  <article class="relative z-10 max-w-screen-xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
      >
        <FaWhatsapp className="text-[#25D366] text-lg" />
        <span class="text-[#25D366] font-semibold text-sm"
          >Servicio Destacado</span
        >
      </div>

      <h2 class="mb-6 text-3xl font-black text-white md:text-4xl lg:text-5xl">
        ¿Pierdes mensajes de clientes en WhatsApp?
        <span
          class="block bg-gradient-to-r from-[#25D366] to-[#128C7E] bg-clip-text text-transparent"
        >
          Organiza todo en una sola plataforma
        </span>
      </h2>

      <p class="max-w-2xl mx-auto text-lg text-gray-300">
        Centraliza la atencion de tu negocio en WhatsApp, asigna chats a tu
        equipo y responde mas rapido desde una plataforma web profesional.
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="grid gap-8 lg:grid-cols-2 lg:items-center mb-12">
      <!-- Left Content -->
      <div class="space-y-8">
        <!-- Before/After Mini -->
        <div class="grid gap-4 sm:grid-cols-2">
          <!-- Before -->
          <div
            class="p-5 border rounded-xl bg-gradient-to-br from-red-500/10 to-red-600/10 border-red-500/20"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">😵</span>
              <h3 class="text-lg font-bold text-red-400">Sin ChatWoot</h3>
            </div>
            <ul class="space-y-2">
              <li class="flex items-start gap-2">
                <span class="text-red-400">•</span>
                <span class="text-sm text-gray-300">Mensajes olvidados</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400">•</span>
                <span class="text-sm text-gray-300">Clientes sin seguimiento</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400">•</span>
                <span class="text-sm text-gray-300">Respuestas tardias</span>
              </li>
            </ul>
          </div>

          <!-- After -->
          <div
            class="p-5 rounded-xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="text-2xl">🤩</span>
              <h3 class="text-lg font-bold text-[#25D366]">Con ChatWoot</h3>
            </div>
            <ul class="space-y-2">
              <li class="flex items-start gap-2">
                <FaCheckCircle
                  className="text-[#25D366] mt-0.5 text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">WhatsApp organizado</span>
              </li>
              <li class="flex items-start gap-2">
                <FaCheckCircle
                  className="text-[#25D366] mt-0.5 text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">Historial completo</span>
              </li>
              <li class="flex items-start gap-2">
                <FaCheckCircle
                  className="text-[#25D366] mt-0.5 text-sm flex-shrink-0"
                />
                <span class="text-sm text-gray-300">Respuestas mas rapidas</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-3 gap-4">
          <div
            class="text-center p-4 rounded-xl bg-gradient-to-br from-[#25D366]/10 to-[#128C7E]/10 border border-[#25D366]/20"
          >
            <div class="text-2xl font-bold text-[#25D366]">5x</div>
            <div class="text-xs text-gray-400">Más Rápido</div>
          </div>
          <div
            class="p-4 text-center border rounded-xl bg-gradient-to-br from-blue-500/10 to-purple-600/10 border-blue-500/20"
          >
            <div class="text-2xl font-bold text-blue-400">100%</div>
            <div class="text-xs text-gray-400">Organizado</div>
          </div>
          <div
            class="p-4 text-center border rounded-xl bg-gradient-to-br from-purple-500/10 to-pink-600/10 border-purple-500/20"
          >
            <div class="text-2xl font-bold text-purple-400">24/7</div>
            <div class="text-xs text-gray-400">Disponible</div>
          </div>
        </div>

        <!-- Key Benefits -->
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 border border-[#25D366]/30"
            >
              <FaUsers className="text-[#25D366]" />
            </div>
            <span class="text-gray-300"
              >Centraliza todas las conversaciones de WhatsApp</span
            >
          </div>
          <div class="flex items-center gap-3">
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-600/20 border border-blue-500/30"
            >
              <FaChartLine className="text-blue-400" />
            </div>
            <span class="text-gray-300"
              >Historial completo para cada cliente</span
            >
          </div>
          <div class="flex items-center gap-3">
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-r from-yellow-500/20 to-orange-600/20 border border-yellow-500/30"
            >
              <FaBolt className="text-yellow-400" />
            </div>
            <span class="text-gray-300"
              >Etiquetas, asignaciones y respuestas rapidas</span
            >
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4">
          <a
            href="https://wa.me/593988949117?text=Hola%20RysthDesign%2C%20quiero%20solicitar%20una%20demostracion%20de%20ChatWoot%20para%20organizar%20la%20atencion%20por%20WhatsApp%20de%20mi%20negocio."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-full text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105"
          >
            <FaWhatsapp className="text-lg" />
            <span>Solicita una demostracion</span>
          </a>

          <a
            href="/servicios/chatwoot"
            class="inline-flex items-center gap-2 px-6 py-4 text-[#25D366] border-2 border-[#25D366]/50 rounded-full hover:bg-[#25D366]/10 transition-all duration-300 font-semibold"
          >
            <span>Conoce como funciona</span>
            <FaArrowRight className="text-sm" />
          </a>
        </div>
      </div>

      <!-- Right - Dashboard Preview -->
      <div class="relative">
        <div class="relative overflow-hidden shadow-2xl rounded-2xl">
          <div
            class="absolute inset-0 bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20 z-10"
          >
          </div>
          <Image
            src={ServiceImage}
            alt="Panel web de atencion por WhatsApp"
            class="object-cover w-full h-80"
          />
        </div>

        <!-- Floating Badge -->
        <div
          class="absolute -bottom-4 -left-4 p-4 rounded-xl shadow-lg bg-gradient-to-br from-[#1a1a2e]/95 to-[#2d2d44]/95 backdrop-blur-xl border border-[#25D366]/30 animate-float hidden md:block"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-r from-[#25D366]/20 to-[#128C7E]/20"
            >
              <FaWhatsapp className="text-[#25D366] text-xl" />
            </div>
            <div>
              <div class="text-xs font-semibold text-white">Implementacion</div>
              <div class="text-lg font-black text-[#25D366]">1-3 dias</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</section>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>
