---
import {
  FaStar,
  FaQuoteLeft,
  FaHandshake,
  FaChartLine,
  FaShieldAlt,
} from "react-icons/fa";
import Project_1 from "@/assets/images/projects/project_1.png";
import Project_2 from "@/assets/images/projects/project_2.png";
import Project_3 from "@/assets/images/projects/project_3.webp";
import { Image } from "astro:assets";
---

<!-- Sección de Clientes - Layout Horizontal con diseño vertical -->
<section
  class="relative px-4 py-16 overflow-hidden bg-dark-gradient"
  id="clientes"
>
  <!-- Elementos decorativos de fondo -->
  <div class="absolute inset-0 opacity-20">
    <div
      class="absolute rounded-full top-20 right-10 w-80 h-80 bg-purple-500/10 blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute rounded-full bottom-20 left-10 w-96 h-96 bg-blue-500/10 blur-3xl animate-float"
      style="animation-delay: 3s;"
    >
    </div>
  </div>

  <article class="relative z-10 max-w-screen-xl mx-auto">
    <!-- Header Section -->
    <div class="mb-16 space-y-6 text-center">
      <div
        class="flex items-center justify-center gap-2 text-[#a78bfa] font-jetbrains text-sm uppercase tracking-wider"
      >
        <div class="w-2 h-2 bg-[#a78bfa] rounded-full animate-pulse"></div>
        <span>Casos de Éxito Reales</span>
      </div>

      <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl">
        Proyectos que están
        <span
          class="bg-gradient-to-r from-[#a78bfa] to-[#4361ee] bg-clip-text text-transparent"
        >
          Transformando Negocios
        </span>
        Reales
      </h2>

      <p
        class="max-w-3xl mx-auto text-base leading-relaxed text-gray-300 md:text-lg"
      >
        Conoce los resultados reales que han obtenido nuestros clientes con
        sistemas web personalizados que están funcionando y generando valor día
        a día.
      </p>
    </div>

    <!-- Testimonials Grid - Real Projects -->
    <div class="grid gap-8 mb-16 md:grid-cols-2 lg:grid-cols-3">
      <!-- QuickInventory Case -->
      <div class="relative group">
        <div
          class="absolute inset-0 transition-opacity duration-300 opacity-0 gradient-primary rounded-2xl group-hover:opacity-10"
        >
        </div>
        <div
          class="relative h-full bg-card-gradient backdrop-blur-xl border border-primary rounded-2xl transition-all duration-300 group-hover:border-[#a78bfa]/40 overflow-hidden"
        >
          <!-- Project Image -->
          <div
            class="overflow-hidden cursor-pointer h-72"
            onclick="modal_quickinventory.showModal()"
          >
            <Image
              src={Project_1}
              alt="QuickInventory Sistema"
              class="object-cover w-full h-full transition-transform duration-300 group-hover:scale-105"
            />
          </div>

          <div class="p-6">
            <!-- Quote Icon -->
            <div
              class="flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-gradient-to-r from-[#a78bfa]/20 to-[#4361ee]/20 border border-primary"
            >
              <FaQuoteLeft className="text-[#a78bfa] text-lg" />
            </div>

            <!-- Testimonio -->
            <blockquote class="mb-4 text-sm leading-relaxed text-gray-300">
              "QuickInventory revolucionó nuestro negocio. Antes perdíamos
              productos por mal control de stock. Ahora tenemos todo organizado,
              reportes automáticos y hemos reducido pérdidas en un 35%."
            </blockquote>

            <!-- Rating -->
            <div class="flex gap-1 mb-4">
              {
                [...Array(5)].map(() => (
                  <FaStar className="text-yellow-400 text-sm" />
                ))
              }
            </div>

            <!-- Cliente Info -->
            <div class="pt-4 border-t border-gray-700">
              <h4 class="text-sm font-semibold text-white">
                QuickInventory Cliente
              </h4>
              <p class="text-xs text-gray-400">Comercio de Productos Varios</p>
              <p class="text-[#a78bfa] text-xs font-medium mt-1">
                Sistema POS + Inventario
              </p>
              <div class="flex gap-2 mt-2">
                <span class="text-white badge badge-xs bg-[#4361ee]"
                  >Ruby on Rails</span
                >
                <span class="text-white bg-green-600 badge badge-xs"
                  >PostgreSQL</span
                >
              </div>
              <button
                onclick="modal_quickinventory.showModal()"
                class="inline-block mt-2 text-xs text-[#a78bfa] hover:text-[#8b5cf6] transition-colors underline"
              >
                Ver detalles completos →
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- TrámitesEC Case -->
      <div class="relative group">
        <div
          class="absolute inset-0 transition-opacity duration-300 opacity-0 gradient-secondary rounded-2xl group-hover:opacity-10"
        >
        </div>
        <div
          class="relative h-full bg-card-gradient backdrop-blur-xl border border-secondary rounded-2xl transition-all duration-300 group-hover:border-[#4361ee]/40 overflow-hidden"
        >
          <!-- Project Image -->
          <div
            class="overflow-hidden cursor-pointer h-72"
            onclick="modal_tramites.showModal()"
          >
            <Image
              src={Project_2}
              alt="TrámitesEC Sistema"
              class="object-cover w-full h-full transition-transform duration-300 group-hover:scale-105"
            />
          </div>

          <div class="p-6">
            <div
              class="flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-gradient-to-r from-[#4361ee]/20 to-[#6366f1]/20 border border-secondary"
            >
              <FaQuoteLeft className="text-[#4361ee] text-lg" />
            </div>

            <blockquote class="mb-4 text-sm leading-relaxed text-gray-300">
              "Con TrámitesEC hemos digitalizado completamente nuestros
              procesos. Aumentamos nuestra capacidad de procesamiento en 70% y
              reducimos errores drásticamente. Lleva 2+ años funcionando
              perfecto."
            </blockquote>

            <div class="flex gap-1 mb-4">
              {
                [...Array(5)].map(() => (
                  <FaStar className="text-yellow-400 text-sm" />
                ))
              }
            </div>

            <div class="pt-4 border-t border-gray-700">
              <h4 class="text-sm font-semibold text-white">
                TrámitesEC Cliente
              </h4>
              <p class="text-xs text-gray-400">Empresa de Gestión Documental</p>
              <p class="text-[#4361ee] text-xs font-medium mt-1">
                Gestión de Trámites
              </p>
              <div class="flex gap-2 mt-2">
                <span class="text-white bg-blue-600 badge badge-xs">React</span>
                <span class="text-white badge badge-xs bg-[#4361ee]"
                  >Rails API</span
                >
              </div>
              <button
                onclick="modal_tramites.showModal()"
                class="inline-block mt-2 text-xs text-[#4361ee] hover:text-[#6366f1] transition-colors underline"
              >
                Ver detalles completos →
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- GoCar Case -->
      <div class="relative group">
        <div
          class="absolute inset-0 transition-opacity duration-300 opacity-0 gradient-tertiary rounded-2xl group-hover:opacity-10"
        >
        </div>
        <div
          class="relative h-full bg-card-gradient backdrop-blur-xl border border-tertiary rounded-2xl transition-all duration-300 group-hover:border-[#6366f1]/40 overflow-hidden"
        >
          <!-- Project Image -->
          <div
            class="overflow-hidden cursor-pointer h-72"
            onclick="modal_gocar.showModal()"
          >
            <Image
              src={Project_3}
              alt="GoCar 2026 - Sistema de Selección de Boletos"
              class="object-cover w-full h-full transition-transform duration-300 group-hover:scale-105"
            />
          </div>

          <div class="p-6">
            <div
              class="flex items-center justify-center w-12 h-12 mb-4 rounded-full bg-gradient-to-r from-[#6366f1]/20 to-[#8b5cf6]/20 border border-tertiary"
            >
              <FaQuoteLeft className="text-[#6366f1] text-lg" />
            </div>

            <blockquote class="mb-4 text-sm leading-relaxed text-gray-300">
              "GoCar nos permitió digitalizar completamente la venta de boletos
              con selección de asientos en tiempo real, integración de pagos vía
              Payphone y una interfaz profesional que eleva la experiencia de
              nuestros usuarios."
            </blockquote>

            <div class="flex gap-1 mb-4">
              {
                [...Array(5)].map(() => (
                  <FaStar className="text-yellow-400 text-sm" />
                ))
              }
            </div>

            <div class="pt-4 border-t border-gray-700">
              <h4 class="text-sm font-semibold text-white">GoCar 2026</h4>
              <p class="text-xs text-gray-400">Enero – Abril 2026</p>
              <p class="text-[#6366f1] text-xs font-medium mt-1">
                Sistema de Selección de Boletos
              </p>
              <div class="flex flex-wrap gap-2 mt-2">
                <span class="text-white bg-blue-600 badge badge-xs">React</span>
                <span class="text-white bg-purple-600 badge badge-xs"
                  >Zustand</span
                >
                <span class="text-white badge badge-xs bg-[#4361ee]"
                  >Rails API</span
                >
                <span class="text-white bg-green-600 badge badge-xs"
                  >PostgreSQL</span
                >
                <span class="text-white bg-blue-800 badge badge-xs">Docker</span
                >
              </div>
              <button
                onclick="modal_gocar.showModal()"
                class="inline-block mt-2 text-xs text-[#6366f1] hover:text-[#8b5cf6] transition-colors underline"
              >
                Ver detalles completos →
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Modales para los proyectos - Adaptados para fondo oscuro -->
  <dialog id="modal_quickinventory" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box bg-[#1a1a1a] text-white max-w-2xl">
      <!-- Project Image -->
      <div class="overflow-hidden mb-4 rounded-xl">
        <Image
          src={Project_1}
          alt="QuickInventory Sistema"
          class="object-cover w-full h-52"
        />
      </div>
      <h3 class="text-lg font-bold">
        QuickInventory - Sistema de Inventario y POS
      </h3>
      <div class="py-4">
        <p class="mb-3">
          Sistema completo para la gestión de inventarios y punto de venta,
          diseñado específicamente para pequeños y medianos comercios.
        </p>
        <h4 class="mb-2 font-semibold">Características principales:</h4>
        <ul class="pl-5 mb-4 space-y-1 text-gray-300 list-disc">
          <li>Control de inventario en tiempo real</li>
          <li>Gestión de proveedores y compras</li>
          <li>Sistema POS con interfaz táctil intuitiva</li>
          <li>Reportes de ventas e inventario</li>
          <li>Gestión de usuarios y permisos</li>
          <li>Alertas de stock bajo</li>
        </ul>
        <h4 class="mb-2 font-semibold">Tecnologías utilizadas:</h4>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-white bg-red-500 badge badge-sm">Ruby on Rails</span
          >
          <span class="text-white badge badge-sm bg-cyan-600">TailwindCSS</span>
          <span class="text-white bg-green-500 badge badge-sm">PostgreSQL</span>
          <span class="text-white bg-blue-500 badge badge-sm">Docker</span>
          <span class="text-white bg-purple-500 badge badge-sm">Hotwire</span>
        </div>
        <h4 class="mb-2 font-semibold">Resultados del cliente:</h4>
        <p class="text-gray-300">
          El cliente experimentó una reducción del 35% en pérdidas de inventario
          y un aumento del 20% en eficiencia operativa tras 6 meses de uso.
        </p>
      </div>
      <div class="modal-action">
        <form method="dialog">
          <button class="bg-[#4361ee] text-white hover:bg-opacity-90 btn">
            Cerrar
          </button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>cerrar</button>
    </form>
  </dialog>

  <dialog id="modal_tramites" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box bg-[#1a1a1a] text-white max-w-2xl">
      <!-- Project Image -->
      <div class="overflow-hidden mb-4 rounded-xl">
        <Image
          src={Project_2}
          alt="TrámitesEC Sistema"
          class="object-cover w-full h-52"
        />
      </div>
      <h3 class="text-lg font-bold">
        TrámitesEC - Sistema de Gestión de Trámites
      </h3>
      <div class="py-4">
        <p class="mb-3">
          Aplicación web completa para la gestión de trámites gubernamentales,
          clientes y pagos, en uso continuo por más de 2 años por una empresa de
          gestión documental.
        </p>
        <h4 class="mb-2 font-semibold">Características principales:</h4>
        <ul class="pl-5 mb-4 space-y-1 text-gray-300 list-disc">
          <li>Gestión de clientes y seguimiento de trámites</li>
          <li>Panel de administración para tramitadores</li>
          <li>Sistema de notificaciones por email y WhatsApp</li>
          <li>Generación de documentos personalizados</li>
          <li>Reportes financieros y operativos</li>
          <li>Interfaz responsive para acceso móvil</li>
        </ul>
        <h4 class="mb-2 font-semibold">Tecnologías utilizadas:</h4>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-white bg-blue-500 badge badge-sm">React</span>
          <span class="text-white bg-red-500 badge badge-sm">Ruby on Rails</span
          >
          <span class="text-white bg-green-500 badge badge-sm">PostgreSQL</span>
          <span class="text-white bg-yellow-500 badge badge-sm">Redux</span>
          <span class="text-white bg-purple-500 badge badge-sm">AWS S3</span>
        </div>
        <h4 class="mb-2 font-semibold">Resultados del cliente:</h4>
        <p class="text-gray-300">
          TrámitesEC ha permitido a la empresa aumentar su capacidad de
          procesamiento en un 70%, reducir errores en documentación y mejorar la
          satisfacción de sus clientes.
        </p>
      </div>
      <div class="modal-action">
        <form method="dialog">
          <button class="bg-[#4361ee] text-white hover:bg-opacity-90 btn">
            Cerrar
          </button>
        </form>
      </div>
    </div>

    <form method="dialog" class="modal-backdrop">
      <button>cerrar</button>
    </form>
  </dialog>

  <!-- GoCar Modal -->
  <dialog id="modal_gocar" class="modal modal-bottom sm:modal-middle">
    <div class="modal-box bg-[#1a1a1a] text-white max-w-2xl">
      <!-- Project Image -->
      <div class="overflow-hidden mb-4 rounded-xl">
        <Image
          src={Project_3}
          alt="GoCar 2026 - Sistema de Selección de Boletos"
          class="object-cover w-full h-52"
        />
      </div>
      <h3 class="text-lg font-bold">
        GoCar 2026 - Sistema de Selección de Boletos en Tiempo Real
      </h3>
      <div class="py-4">
        <p class="mb-3">
          Sistema completo de selección de boletos con persistencia en base de
          datos y validación de pagos, desarrollado entre enero y abril de 2026.
        </p>
        <h4 class="mb-2 font-semibold">Características principales:</h4>
        <ul class="pl-5 mb-4 space-y-1 text-gray-300 list-disc">
          <li>
            🎫 Selección de boletos en tiempo real con persistencia en base de
            datos
          </li>
          <li>💳 Validación de pagos integrada vía Payphone</li>
          <li>🎨 Interfaz de usuario profesional con ShadCN</li>
          <li>🖼️ Gestión de imágenes de premios con Cloudflare R2</li>
          <li>📊 Estado global de la aplicación con Zustand</li>
          <li>🐳 Infraestructura containerizada con Docker</li>
        </ul>
        <h4 class="mb-2 font-semibold">Tecnologías utilizadas:</h4>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-white bg-blue-500 badge badge-sm">React</span>
          <span class="text-white bg-purple-600 badge badge-sm">Zustand</span>
          <span class="text-white bg-red-500 badge badge-sm"
            >Ruby on Rails (API)</span
          >
          <span class="text-white bg-green-500 badge badge-sm">PostgreSQL</span>
          <span class="text-white bg-blue-800 badge badge-sm">Docker</span>
          <span class="text-white bg-gray-600 badge badge-sm">ShadCN</span>
          <span class="text-white bg-orange-500 badge badge-sm"
            >Cloudflare R2</span
          >
          <span class="text-white bg-teal-600 badge badge-sm">Payphone</span>
        </div>
        <h4 class="mb-2 font-semibold">Período de desarrollo:</h4>
        <p class="text-gray-300">
          Enero 2026 – Abril 2026. Sistema en producción con selección de
          asientos en tiempo real, evitando doble reservas gracias a la
          persistencia inmediata en base de datos.
        </p>
      </div>
      <div class="modal-action">
        <form method="dialog">
          <button class="bg-[#4361ee] text-white hover:bg-opacity-90 btn">
            Cerrar
          </button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>cerrar</button>
    </form>
  </dialog>
</section>
